# Optional outside Netlify. Netlify automatically supplies URL/DEPLOY_PRIME_URL.
SITE_URL=https://your-production-domain.example

# Server-only Interpeko configuration. Never use a PUBLIC_ prefix for this key.
OPENAI_API_KEY=
INTERPEKO_MODEL=gpt-5.6-terra

# Optional independent secret used to pseudonymise public rate-limit identifiers.
RATE_LIMIT_SALT=
