---
interface Props {
  title: string;
  summary: string;
  category: string;
  type: string;
  author: string;
  pages: number;
  size: string;
  href: string;
  thumbnail: string;
  topics: readonly string[];
}

const { title, summary, category, type, author, pages, size, href, thumbnail, topics } = Astro.props;
const searchText = `${title} ${summary} ${author} ${category} ${type} ${topics.join(' ')}`.toLowerCase();
---

<article class="media-card resource-card" data-category="Learning materials" data-search={searchText}>
  <div class="media-card__preview">
    <img src={thumbnail} width="1333" height="750" alt={`Preview cover for ${title}`} loading="lazy" decoding="async" />
    <span class="media-card__type"><span class="icon icon--file" aria-hidden="true"></span>{type}</span>
  </div>
  <div class="media-card__body">
    <div class="resource-card__meta"><span>{category}</span><span>{pages} pages</span><span>{size}</span></div>
    <h3><a href={href} target="_blank" rel="noopener">{title}<span class="sr-only"> (opens in a new tab)</span></a></h3>
    <p>{summary}</p>
    <p class="media-card__author">Attributed to {author}</p>
    <div class="media-card__actions" aria-label={`Actions for ${title}`}>
      <button
        class="media-action media-action--preview"
        type="button"
        data-media-open
        data-media-title={title}
        data-media-summary={summary}
        data-media-thumbnail={thumbnail}
        data-media-href={href}
        data-media-meta={`${type} · ${pages} pages · ${size}`}
      ><span class="icon icon--eye" aria-hidden="true"></span>Preview</button>
      <a class="media-action" href={href} target="_blank" rel="noopener"><span class="icon icon--up-right" aria-hidden="true"></span>View<span class="sr-only"> (opens in a new tab)</span></a>
      <a class="media-action" href={href} download><span class="icon icon--download" aria-hidden="true"></span>Download</a>
    </div>
  </div>
</article>

<style>
  .media-card{min-height:0;padding:0;overflow:hidden}.media-card__preview{position:relative;display:grid;place-items:center;aspect-ratio:16/9;padding:1rem;background:#f4f1f5;border-bottom:1px solid var(--line)}.media-card__preview img{width:100%;height:100%;object-fit:contain;border-radius:.55rem}.media-card__type{position:absolute;left:1rem;bottom:1rem;display:inline-flex;align-items:center;gap:.4rem;padding:.42rem .62rem;color:var(--plum-900);background:rgba(255,255,255,.94);border:1px solid rgba(255,255,255,.7);border-radius:999px;box-shadow:0 3px 12px rgba(31,13,41,.07);font-size:.74rem;font-weight:800;letter-spacing:.04em}.media-card__body{display:flex;flex:1;flex-direction:column;padding:1.4rem}.media-card h3{margin-top:1.7rem}.media-card__author{margin-top:.8rem;color:var(--plum-700);font-size:.79rem;font-weight:700}.media-card__actions{display:flex;flex-wrap:wrap;gap:.45rem;margin-top:auto;padding-top:1.4rem}.media-action{min-height:2.55rem;display:inline-flex;align-items:center;justify-content:center;gap:.42rem;padding:.55rem .7rem;color:var(--plum-800);background:var(--white);border:1px solid var(--line);border-radius:.65rem;font-size:.8rem;font-weight:750;text-decoration:none;transition:color .25s var(--ease-premium),background .25s var(--ease-premium),border-color .25s var(--ease-premium),transform .25s var(--ease-premium)}.media-action:hover{color:var(--white);background:var(--plum-700);border-color:var(--plum-700);text-decoration:none;transform:translateY(-1px)}.media-action--preview{color:var(--white);background:var(--plum-800);border-color:var(--plum-800)}
</style>
