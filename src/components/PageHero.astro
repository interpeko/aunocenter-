---
interface Props {
  eyebrow?: string;
  title: string;
  lead: string;
  tone?: 'light' | 'dark' | 'gold';
}
const { eyebrow, title, lead, tone = 'dark' } = Astro.props;
---

<section class:list={['page-hero', `page-hero--${tone}`]}>
  <div class="page-hero__orb page-hero__orb--one" aria-hidden="true"></div>
  <div class="page-hero__orb page-hero__orb--two" aria-hidden="true"></div>
  <div class="shell page-hero__inner">
    <div class="page-hero__copy">
      {eyebrow && <p class:list={['eyebrow', tone === 'dark' && 'eyebrow--light']}>{eyebrow}</p>}
      <h1>{title}</h1>
      <p class="page-hero__lead">{lead}</p>
      <slot name="actions" />
    </div>
    <div class="page-hero__mark" aria-hidden="true">
      <span>A</span><i></i>
      <small>{String(new Date().getFullYear()).slice(2)}</small>
    </div>
  </div>
</section>
