---
import type { Service } from '@/data/site';
interface Props { service: Service; featured?: boolean }
const { service, featured = false } = Astro.props;
---

<article class:list={['service-card', `service-card--${service.accent}`, featured && 'service-card--featured']}>
  <div class="service-card__top">
    <span class="service-card__number">{service.number}</span>
    <span class="service-card__arrow" aria-hidden="true">↗</span>
  </div>
  <h3><a href={`/services/${service.slug}/`}>{service.title}</a></h3>
  <p>{service.summary}</p>
  <a class="text-link" href={`/services/${service.slug}/`} aria-label={`Explore ${service.title}`}>Explore this service <span aria-hidden="true">→</span></a>
</article>
