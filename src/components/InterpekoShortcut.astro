<aside class="interpeko-shortcut" aria-label="Interpeko assistant shortcut" data-interpeko-shortcut>
  <a href="/interpeko/" aria-label="Open Interpeko academic research assistant">
    <span class="interpeko-shortcut__orb" aria-hidden="true">I</span>
    <span class="interpeko-shortcut__copy">
      <strong>Ask Interpeko</strong>
      <small>AI + guided research</small>
    </span>
    <span class="interpeko-shortcut__arrow" aria-hidden="true">↗</span>
  </a>
</aside>

<script>
  const shortcut = document.querySelector<HTMLElement>('[data-interpeko-shortcut]');
  const footer = document.querySelector<HTMLElement>('.site-footer');
  if (shortcut && footer && 'IntersectionObserver' in window) {
    const observer = new IntersectionObserver(([entry]) => {
      shortcut.toggleAttribute('data-footer-visible', entry.isIntersecting);
    }, { threshold: .04 });
    observer.observe(footer);
  }
</script>

