---
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
  align?: 'left' | 'center';
  light?: boolean;
}
const { eyebrow, title, text, align = 'left', light = false } = Astro.props;
---

<div class:list={['section-heading', `section-heading--${align}`, light && 'section-heading--light']}>
  {eyebrow && <p class:list={['eyebrow', light && 'eyebrow--light']}>{eyebrow}</p>}
  <h2>{title}</h2>
  {text && <p>{text}</p>}
</div>
