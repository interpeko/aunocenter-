---
import BaseLayout from '@/layouts/BaseLayout.astro';import Breadcrumbs from '@/components/Breadcrumbs.astro';import PageHero from '@/components/PageHero.astro';const crumbs=[{label:'Join AUNO Center'}];const roles=['Research collaborator','Research support consultant','Scientific writer or editor','Statistician or data analyst','Trainer or course contributor','Web developer or digital specialist','Designer or media contributor','Volunteer or community contributor','Student or early-career member','Institutional representative','Other professional interest'];
---
<BaseLayout title="Join AUNO Center | Professional Interest Portal" description="Express professional interest in contributing to AUNO Center research, education, collaboration, and institutional programs." breadcrumbs={crumbs}><Breadcrumbs items={crumbs}/><PageHero eyebrow="Contribute with purpose" title="Join a connected research community." lead="Express interest in research collaboration, education, professional support, institutional work, or community contribution. Every submission is reviewed; no role, work, payment, or appointment is guaranteed."/><section class="section"><div class="shell content-grid"><div><p class="eyebrow">Ways to contribute</p><h2>Expertise, learning, and responsible collaboration.</h2><div class="number-grid mt-3">{roles.slice(0,6).map((role,index)=><article class="number-card"><span class="number-card__index">{String(index+1).padStart(2,'0')}</span><h3>{role}</h3><p>Interest is matched only to verified needs, capability, safeguarding requirements, and suitable institutional scope.</p></article>)}</div></div><aside class="sticky-aside"><div class="side-card"><h2>What happens next</h2><ol><li>Submission is received privately through Netlify.</li><li>Relevant experience and interests are reviewed.</li><li>AUNO Center may request clarification or a conversation.</li><li>Any opportunity, responsibilities, terms, and checks are confirmed separately in writing.</li></ol></div><div class="notice"><p>Application data and CVs are not stored in the public GitHub repository. Do not include identity documents, patient data, financial data, passwords, or confidential third-party material.</p></div></aside></div></section><section class="section section--ivory" id="join-form"><div class="shell form-page-grid"><div><p class="eyebrow">Professional interest form</p><h2>Tell us what you can contribute and hope to develop.</h2><p>Submit only information you are authorised to share.</p></div><form class="form-shell" name="join-auno-application" method="POST" action="/thank-you/?form=join" data-netlify="true" netlify-honeypot="bot-field" enctype="multipart/form-data"><input type="hidden" name="form-name" value="join-auno-application"/><p class="honeypot"><label>Leave empty: <input name="bot-field"/></label></p><fieldset class="form-section"><legend>Profile</legend><div class="form-grid"><div class="form-field"><label for="join-name">Full name *</label><input id="join-name" name="full-name" autocomplete="name" required/></div><div class="form-field"><label for="join-email">Professional email *</label><input id="join-email" name="email" type="email" autocomplete="email" required/></div><div class="form-field"><label for="join-country">Country and time zone *</label><input id="join-country" name="country-time-zone" required/></div><div class="form-field"><label for="join-org">Institution or organisation</label><input id="join-org" name="organisation" autocomplete="organization"/></div><div class="form-field"><label for="join-role">Primary interest *</label><select id="join-role" name="primary-interest" required><option value="">Select</option>{roles.map(role=><option>{role}</option>)}</select></div><div class="form-field"><label for="join-field">Discipline or professional field *</label><input id="join-field" name="professional-field" required/></div><div class="form-field form-field--full"><label for="join-profile">Professional profile or public portfolio URL</label><input id="join-profile" name="profile-url" type="url" placeholder="https://"/></div></div></fieldset><fieldset class="form-section"><legend>Contribution</legend><div class="form-grid"><div class="form-field form-field--full"><label for="join-experience">Relevant experience and capabilities *</label><textarea id="join-experience" name="experience" required></textarea></div><div class="form-field form-field--full"><label for="join-interest">Why AUNO Center, and what would you contribute? *</label><textarea id="join-interest" name="motivation-contribution" required></textarea></div><div class="form-field form-field--full"><label for="join-cv">CV or résumé (optional; PDF, DOC, or DOCX)</label><input id="join-cv" name="cv" type="file" accept=".pdf,.doc,.docx,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document"/><small>Submit only your own CV. Recommended maximum: 5 MB.</small></div></div></fieldset><label class="check-row"><input name="privacy-consent" type="checkbox" value="yes" required/><span>I have read the <a href="/privacy/">Privacy Policy</a>, am authorised to share this information, and consent to its review. *</span></label><label class="check-row"><input name="no-guarantee-acknowledgement" type="checkbox" value="yes" required/><span>I understand this expression of interest does not guarantee selection, work, payment, membership, or appointment. *</span></label><div class="form-actions"><p>CV files are handled as private form submissions, not public website files.</p><button class="button button--primary" type="submit">Submit professional interest</button></div></form></div></section></BaseLayout>
