---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import PageHero from '@/components/PageHero.astro';
const crumbs=[{label:'Research consultancy disclaimer'}];
const responsibilities=['Accuracy, legality, provenance, and permitted use of data and materials','Ethics, privacy, institutional, funder, publisher, professional, and regulatory requirements','Final methodological, statistical, clinical, and professional decisions','Verification of calculations, citations, outputs, interpretations, and conclusions','Appropriate disclosure of consultancy, editorial, statistical, translation, and AI assistance','Authorship, contribution, acknowledgement, and conflict decisions','Secure handling of confidential, identifiable, proprietary, and otherwise sensitive information'];
---

<BaseLayout title="Research Consultancy Disclaimer | AUNO Center" description="Important limitations, responsibilities, research-integrity boundaries, healthcare safeguards, and outcome disclaimers for AUNO Center support." breadcrumbs={crumbs}>
  <Breadcrumbs items={crumbs}/><PageHero eyebrow="Professional boundary" title="Research Consultancy Disclaimer" lead="AUNO Center provides educational, methodological, analytical, editorial, and capacity-building support. Public website content and initial communications are general information, not project-specific professional advice." />
  <section class="section"><div class="shell disclaimer-intro"><div class="notice notice--critical"><h2>No guaranteed outcome</h2><p>AUNO Center does not guarantee publication, funding, academic grades, ethics approval, regulatory approval, institutional acceptance, statistically significant findings, or any other outcome controlled by third parties or dependent on the underlying research.</p></div><div><p class="eyebrow">Researcher responsibility</p><h2>Support does not transfer accountability.</h2><p>Researchers and institutions remain responsible for their source information, decisions, approvals, use of outputs, final work, and communication.</p></div></div></section>
  <section class="section section--ivory"><div class="shell"><div class="section-heading"><p class="eyebrow">Core responsibilities</p><h2>The requester remains responsible for</h2></div><ol class="responsibility-grid">{responsibilities.map((item,index)=><li><span>{String(index+1).padStart(2,'0')}</span><p>{item}</p></li>)}</ol></div></section>
  <section class="section"><div class="shell content-grid"><article class="prose"><h2 class="mt-0">Research integrity</h2><p>AUNO Center does not support plagiarism, fabricated or falsified data, invented citations, undisclosed ghost authorship, misleading statistical practices, manipulation or concealment of results, circumvention of academic rules, or bypassing ethics and institutional requirements.</p><h2>Statistical and methodological limits</h2><p>Results depend on study design, data quality, measurement, sampling, assumptions, missingness, analytical choices, uncertainty, and context. No method can guarantee a desired finding or repair data that cannot credibly answer the question.</p><h2>Healthcare and clinical boundary</h2><p>Healthcare-related support is for research purposes. It is not diagnosis, treatment, medical advice, emergency assistance, legal advice, privacy advice, regulatory approval, or ethics approval. It must not replace qualified clinical or institutional judgement.</p><h2>Public resources</h2><p>Articles, checklists, website pages, and initial communications are general educational information. They are not tailored to a project or jurisdiction and should not be relied on as a substitute for authorised advice.</p><h2>Engagement terms</h2><p>Any confidential engagement, deliverable, fee, timeline, secure data-transfer process, intellectual-property arrangement, or allocation of responsibility must be governed by a separate agreement or clearly confirmed terms.</p></article><aside class="sticky-aside"><div class="side-card"><h2>Before requesting support</h2><ul class="check-list"><li>Use non-confidential information in the initial form.</li><li>Identify required approvals and institutional rules.</li><li>Be transparent about project stage and deadlines.</li><li>Retain responsibility for verification and final use.</li></ul></div><div class="side-card"><h2>Related information</h2><ul><li><a href="/research-ethics-integrity/">Research Ethics & Integrity</a></li><li><a href="/privacy/">Privacy Policy</a></li><li><a href="/terms/">Terms of Use</a></li></ul></div></aside></div></section>
</BaseLayout>

<style>.disclaimer-intro{display:grid;grid-template-columns:1fr 1fr;gap:clamp(2rem,6vw,6rem);align-items:center}.disclaimer-intro h2{max-width:14ch}.disclaimer-intro div:last-child>p:last-child{margin-top:1rem}.responsibility-grid{display:grid;grid-template-columns:repeat(2,1fr);border:1px solid var(--line);list-style:none}.responsibility-grid li{min-height:8rem;display:grid;grid-template-columns:3rem 1fr;gap:1rem;padding:1.3rem;background:white;border-right:1px solid var(--line);border-bottom:1px solid var(--line)}.responsibility-grid li:nth-child(2n){border-right:0}.responsibility-grid span{color:var(--gold-dark);font-size:.7rem;font-weight:800}.responsibility-grid p{color:var(--ink)}@media(max-width:47.99rem){.disclaimer-intro,.responsibility-grid{grid-template-columns:1fr}.responsibility-grid li,.responsibility-grid li:nth-child(2n){border-right:0}}</style>
