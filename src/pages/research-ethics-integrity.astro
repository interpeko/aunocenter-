---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import PageHero from '@/components/PageHero.astro';
import CallToAction from '@/components/CallToAction.astro';
const crumbs=[{label:'Research ethics & integrity'}];
const principles=[['Respect for persons and communities','Recognise dignity, autonomy, culture, vulnerability, and the knowledge people bring.'],['Benefit and harm','Assess potential benefits, burdens, risks, and safeguards in proportion to the context.'],['Fair participation','Use defensible inclusion, exclusion, recruitment, and compensation practices.'],['Meaningful consent','Provide understandable information and a genuine, ongoing choice where consent is required.'],['Privacy and confidentiality','Minimise data, limit access, protect transfer, and address re-identification risk.'],['Transparent methods','Document decisions, deviations, uncertainty, limitations, and conflicts.'],['Honest contribution','Attribute work fairly and connect authorship with accountability.'],['Responsible reporting','Communicate all findings without fabrication, concealment, distortion, or selective overstatement.']];
---

<BaseLayout title="Research Ethics and Integrity | AUNO Center" description="Explore AUNO Center’s approach to consent, privacy, authorship, data stewardship, transparency, responsible AI, and research integrity." breadcrumbs={crumbs}>
  <Breadcrumbs items={crumbs}/><PageHero eyebrow="Research ethics & integrity" title="Integrity is part of the method." lead="Ethical research is not only a formal approval step. It is an ongoing responsibility to participants, collaborators, institutions, evidence users, and the public." />

  <section class="section"><div class="shell"><div class="section-heading"><p class="eyebrow">Core principles</p><h2>Responsibilities that continue throughout the research lifecycle.</h2></div><div class="integrity-grid">{principles.map(([title,text],index)=><article><span>{String(index+1).padStart(2,'0')}</span><h3>{title}</h3><p>{text}</p></article>)}</div></div></section>

  <section class="section section--ivory"><div class="shell content-grid"><article class="prose"><p class="eyebrow">Integrity in practice</p><h2 class="mt-0">From protocol to public record.</h2>
    <h3>Ethics-ready protocol development</h3><p>Research plans should identify participants or data sources, recruitment and consent routes, potential benefit and harm, privacy safeguards, community considerations, conflicts, and the approvals required before activity begins.</p>
    <h3>Data stewardship</h3><p>Collection, access, transfer, storage, linkage, sharing, retention, and disposal should be defined before data are gathered. Public forms and ordinary email are not suitable for identifiable health or participant information.</p>
    <h3>Authorship and contribution</h3><p>Contribution expectations should be discussed early and reviewed as work evolves. Authorship reflects genuine contribution and accountability; acknowledgement, consultancy disclosure, and contributor statements recognise other forms of support.</p>
    <h3>Responsible use of AI</h3><p>AI-supported work requires critical verification, lawful and secure use, appropriate disclosure, attention to bias and confidentiality, and compliance with institutional, funder, and publisher rules. A tool cannot assume authorship or responsibility.</p>
    <h3>Transparent correction</h3><p>Research credibility is strengthened when material errors are acknowledged and corrected through the appropriate institutional or publication route. Documentation helps teams understand what changed and why.</p>
  </article><aside class="sticky-aside"><div class="notice notice--critical"><h2>Essential boundary</h2><p>AUNO Center is not presented as a research ethics committee or institutional review board. Guidance does not constitute ethics approval.</p></div><div class="side-card"><h2>Required approvals</h2><p>Researchers must obtain all approvals required by their institution, funder, profession, jurisdiction, and research setting before regulated activity begins.</p></div><div class="side-card"><h2>Suspected misconduct</h2><p>Concerns about activity at another institution should use that institution’s official reporting process. AUNO Center does not claim investigative authority.</p></div></aside></div></section>

  <section class="section"><div class="shell"><div class="section-heading"><p class="eyebrow">Support areas</p><h2>Build responsible practice into the work.</h2></div><div class="feature-grid"><article class="feature-card"><span class="feature-card__mark">01</span><h3>Protocol clarity</h3><p>Review how aims, methods, participants, risks, consent, and privacy are described.</p></article><article class="feature-card"><span class="feature-card__mark">02</span><h3>Data management</h3><p>Plan minimum necessary data, access, secure handling, sharing, retention, and responsibilities.</p></article><article class="feature-card"><span class="feature-card__mark">03</span><h3>Contribution planning</h3><p>Support early conversations about authorship, acknowledgements, disclosure, and accountability.</p></article><article class="feature-card"><span class="feature-card__mark">04</span><h3>Integrity education</h3><p>Tailor workshops on responsible reporting, data stewardship, authorship, and AI use.</p></article></div></div></section>
  <CallToAction title="Make integrity visible in every research decision." text="Discuss protocol clarity, research-integrity training, data stewardship, contribution planning, or responsible reporting support." />
</BaseLayout>

<style>
  .integrity-grid{display:grid;grid-template-columns:repeat(4,1fr);border:1px solid var(--line)}.integrity-grid article{min-height:17rem;padding:1.4rem;border-right:1px solid var(--line);border-bottom:1px solid var(--line)}.integrity-grid article:nth-child(4n){border-right:0}.integrity-grid article:nth-last-child(-n+4){border-bottom:0}.integrity-grid span{color:var(--gold-dark);font-size:.7rem;font-weight:800}.integrity-grid h3{margin-top:3rem}.integrity-grid p{margin-top:.7rem;font-size:.9rem}
  @media(max-width:61.99rem){.integrity-grid{grid-template-columns:repeat(2,1fr)}.integrity-grid article:nth-child(2n){border-right:0}.integrity-grid article:nth-child(odd){border-right:1px solid var(--line)}.integrity-grid article:nth-last-child(-n+4){border-bottom:1px solid var(--line)}.integrity-grid article:nth-last-child(-n+2){border-bottom:0}}
  @media(max-width:47.99rem){.integrity-grid{grid-template-columns:1fr}.integrity-grid article,.integrity-grid article:nth-child(odd),.integrity-grid article:nth-child(2n),.integrity-grid article:nth-last-child(-n+2){min-height:auto;border-right:0;border-bottom:1px solid var(--line)}.integrity-grid article:last-child{border-bottom:0}.integrity-grid h3{margin-top:2rem}}
</style>
