---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import PageHero from '@/components/PageHero.astro';
import { SITE } from '@/data/site';
const crumbs=[{label:'Accessibility statement'}];
---

<BaseLayout title="Accessibility Statement | AUNO Center" description="AUNO Center’s accessibility goals, implemented measures, known limitations, testing approach, and route for reporting digital access barriers." breadcrumbs={crumbs}>
  <Breadcrumbs items={crumbs}/><PageHero eyebrow="Digital accessibility" title="Accessibility Statement" lead="AUNO Center wants its website and digital resources to be usable by as many people as possible, including people who use assistive technologies." tone="gold" />
  <section class="section"><div class="shell content-grid"><article class="prose"><p class="lead">This website is designed with the aim of meeting the Web Content Accessibility Guidelines (WCAG) 2.2 Level AA principles. This statement does not claim full conformance without a complete independent accessibility audit.</p><h2>Measures built into the website</h2><ul class="check-list"><li>Semantic landmarks, one primary heading, and a logical heading hierarchy.</li><li>A visible-on-focus “Skip to main content” link.</li><li>Keyboard-operable navigation, forms, filters, search, and FAQ disclosures.</li><li>Visible focus indicators and colour combinations designed for sufficient contrast.</li><li>Responsive layouts intended to reflow at narrow widths and high zoom.</li><li>Plain labels, instructions, required-field indicators, autocomplete information, and native form validation.</li><li>Text alternatives for meaningful images and adjacent HTML alternatives for the social poster.</li><li>No autoplaying media, flashing content, or essential motion.</li><li>Support for reduced-motion and forced-colour preferences.</li><li>Descriptive links and status messages that do not depend only on colour.</li></ul><h2>Compatibility and testing</h2><p>The site is intended to work with current versions of major browsers, keyboard-only navigation, browser zoom, common screen readers, high-contrast settings, and mobile devices. Automated checks help identify some problems, but they do not establish full conformance; manual testing and user feedback remain essential.</p><h2>Known limitations</h2><p>Third-party social platforms, linked external websites, and externally supplied files may have accessibility limitations outside AUNO Center’s direct control. Where practicable, an accessible alternative will be offered on request.</p><h2>Feedback and assistance</h2><p>If you encounter an accessibility barrier, email <a href={`mailto:${SITE.email}?subject=Accessibility%20feedback`}>{SITE.email}</a>. Include the page or resource, a description of the problem, the format or accommodation that would help, and—only if you are comfortable—the browser or assistive technology used.</p><p>Accessibility feedback will be used to prioritise improvements. A direct response time cannot be guaranteed until your message is reviewed.</p><h2>Statement review</h2><p>This statement was prepared for the new AUNO Center website on 11 July 2026 and should be reviewed after major design, content, platform, or accessibility-testing changes.</p></article><aside class="sticky-aside"><div class="side-card"><h2>Report a barrier</h2><p>We welcome clear feedback about content, navigation, forms, colour, keyboard use, screen readers, motion, or document formats.</p><a class="button button--primary" href={`mailto:${SITE.email}?subject=Accessibility%20feedback`}>Email accessibility feedback</a></div><div class="side-card"><h2>Useful details</h2><ul><li>Page or resource address</li><li>What you expected to do</li><li>What prevented access</li><li>An alternative format that would help</li></ul></div></aside></div></section>
</BaseLayout>
