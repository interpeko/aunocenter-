---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import CallToAction from '@/components/CallToAction.astro';
import FounderFeature from '@/components/FounderFeature.astro';
import { SITE, services, resources, focusAreas } from '@/data/site';

const title = 'AUNO Center | Global Research Support and Capacity Building';
const description = 'AUNO Center provides responsible research design, statistics, literature review, training, healthcare research, and institutional support.';
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  description: SITE.description,
  url: new URL('/', Astro.site ?? Astro.url.origin).href
};
---

<BaseLayout title={title} description={description} image="/images/global-research-hero.webp" schema={websiteSchema}>
  <section class="home-hero">
    <img class="home-hero__image" src="/images/global-research-hero.webp" width="1672" height="941" alt="An interdisciplinary research team examining evidence together" fetchpriority="high" />
    <div class="home-hero__veil" aria-hidden="true"></div>
    <div class="shell home-hero__inner">
      <div class="home-hero__copy">
        <p class="eyebrow eyebrow--light">Global research support</p>
        <h1>Research with clarity.<br /><em>Knowledge with purpose.</em></h1>
        <p>AUNO Center supports students, researchers, healthcare professionals, and institutions—from shaping a rigorous question to interpreting and communicating evidence responsibly.</p>
        <div class="button-row">
          <a class="button button--gold" href="/request-support/">Request research support <span aria-hidden="true">↗</span></a>
          <a class="button button--ghost-light" href="/services/">Explore our services</a>
        </div>
      </div>
      <div class="home-hero__signature" aria-label={SITE.tagline}>
        <span>One World.</span>
        <strong>One Research.</strong>
        <small>One Center of Excellence.</small>
      </div>
    </div>
  </section>

  <FounderFeature id="founder" showReadMore={true} />

  <section class="audience-band" aria-labelledby="audience-heading">
    <div class="shell audience-band__inner">
      <h2 id="audience-heading">Research support built around your context</h2>
      <ul>
        <li>Students & early-career researchers</li>
        <li>Academic & professional researchers</li>
        <li>Healthcare & public-health professionals</li>
        <li>Universities, hospitals & institutions</li>
      </ul>
    </div>
  </section>

  <section class="section intro-section">
    <div class="shell intro-grid">
      <div>
        <p class="eyebrow">A connected research journey</p>
        <h2>Strong research begins with strong decisions.</h2>
      </div>
      <div class="intro-copy">
        <p>Every project depends on a connected set of decisions: what to ask, how to investigate it, what evidence to collect, how to analyse it, and how to report it with integrity.</p>
        <p>AUNO Center brings structure to those decisions through practical methodological support, capacity building, and clear communication. Our role is not to replace the researcher. It is to help researchers understand their options, document their reasoning, recognise limitations, and produce work that is transparent, defensible, and useful.</p>
        <a class="text-link" href="/about/">Discover AUNO Center <span aria-hidden="true">→</span></a>
      </div>
    </div>
    <div class="shell research-path" aria-label="AUNO Center research support pathway">
      <div><span>01</span><strong>Question</strong><small>Clarify the problem</small></div>
      <i aria-hidden="true"></i>
      <div><span>02</span><strong>Design</strong><small>Choose a coherent route</small></div>
      <i aria-hidden="true"></i>
      <div><span>03</span><strong>Evidence</strong><small>Analyse with discipline</small></div>
      <i aria-hidden="true"></i>
      <div><span>04</span><strong>Meaning</strong><small>Communicate responsibly</small></div>
    </div>
  </section>

  <section class="section section--ivory">
    <div class="shell">
      <SectionHeading eyebrow="Research services" title="Methodological support across the research lifecycle." text="Receive focused guidance at one stage or connect several stages through a clearly scoped, collaborative engagement." />
      <div class="service-grid">
        {services.map((service) => <ServiceCard service={service} />)}
      </div>
      <div class="center mt-3"><a class="button button--outline" href="/services/">View all research services</a></div>
    </div>
  </section>

  <section class="section principles-section">
    <div class="shell">
      <SectionHeading eyebrow="How we work" title="A responsible approach to research support." text="Good consultancy strengthens the project and the researcher’s ability to understand, explain, and defend the decisions behind it." />
      <div class="principle-grid">
        <article><span>R</span><h3>Rigor before shortcuts</h3><p>Recommendations begin with the question, design, data, context, and appropriate reporting standards.</p></article>
        <article><span>C</span><h3>Capability, not dependency</h3><p>Support is designed to increase understanding and improve future methodological decision-making.</p></article>
        <article><span>I</span><h3>Integrity throughout</h3><p>Authorship, consent, privacy, transparency, conflicts, and responsible reporting remain central.</p></article>
        <article><span>L</span><h3>Clarity without jargon</h3><p>Complex ideas are explained accurately in language that enables informed action.</p></article>
      </div>
    </div>
  </section>

  <section class="section academic-home">
    <div class="shell academic-home__grid">
      <div class="academic-home__copy">
        <p class="eyebrow">Academic practice framework</p>
        <h2>Standards-informed research, from question to correction.</h2>
        <p>AUNO Center’s academic framework makes the decisions behind credible work visible: purpose, protocol, governance, design, measurement, analysis, reporting, contribution, preservation, and correction.</p>
        <div class="button-row"><a class="button button--primary" href="/academic-standards/">Explore the framework</a><a class="button button--outline" href="/interpeko/">Ask Interpeko AI</a></div>
      </div>
      <ol class="academic-cycle" aria-label="Academic practice cycle">
        <li><span>01</span><div><strong>Question</strong><small>Gap, purpose, context</small></div></li>
        <li><span>02</span><div><strong>Protocol</strong><small>Governance, roles, plan</small></div></li>
        <li><span>03</span><div><strong>Design</strong><small>Sampling, measurement, bias</small></div></li>
        <li><span>04</span><div><strong>Analysis</strong><small>Estimands, assumptions, uncertainty</small></div></li>
        <li><span>05</span><div><strong>Reporting</strong><small>Claims, sources, contribution</small></div></li>
        <li><span>06</span><div><strong>Correction</strong><small>Version, provenance, revision</small></div></li>
      </ol>
    </div>
  </section>

  <section class="section section--plum process-section">
    <div class="shell">
      <SectionHeading eyebrow="Engagement pathway" title="A clear path from request to support." text="Every engagement begins with scope, boundaries, responsibilities, and expected outputs—not assumptions." light />
      <div class="number-grid number-grid--dark">
        <article class="number-card"><span class="number-card__index">01 / Share</span><h3>Tell us about your project</h3><p>Submit a short, non-confidential overview of the question, stage, needs, and timeline.</p></article>
        <article class="number-card"><span class="number-card__index">02 / Scope</span><h3>Define the right support</h3><p>We review the request, assess fit, and clarify the most useful and responsible boundaries.</p></article>
        <article class="number-card"><span class="number-card__index">03 / Agree</span><h3>Confirm an approach</h3><p>Deliverables, responsibilities, timing, communication, and any fees are agreed before work begins.</p></article>
        <article class="number-card"><span class="number-card__index">04 / Collaborate</span><h3>Work with transparency</h3><p>Decisions are explained, progress is documented, and next steps stay practical and clear.</p></article>
      </div>
      <div class="button-row process-actions"><a class="button button--gold" href="/request-support/">Start a research support request <span aria-hidden="true">↗</span></a></div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionHeading eyebrow="Research focus" title="Evidence work shaped by real contexts." text="AUNO Center connects core research methods with the specific responsibilities of healthcare, institutional research, ethics, and cross-border collaboration." />
      <div class="feature-grid">
        {focusAreas.map((area) => (
          <article class="feature-card">
            <span class="feature-card__mark">{area.mark}</span>
            <h3>{area.title}</h3>
            <p>{area.text}</p>
            <a class="text-link" href={area.href}>Explore this focus <span aria-hidden="true">→</span></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--ivory">
    <div class="shell resource-feature">
      <div class="resource-feature__intro">
        <p class="eyebrow">Open research resources</p>
        <h2>Practical knowledge for better research.</h2>
        <p>Concise guidance on study design, analysis, questionnaires, evidence synthesis, responsible reporting, integrity, and healthcare data.</p>
        <a class="button button--outline" href="/resources/">Browse all resources</a>
      </div>
      <div class="resource-feature__list">
        {resources.slice(0, 4).map((resource, index) => (
          <a href={`/resources/${resource.slug}/`}>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <div><small>{resource.category} · {resource.readingTime}</small><strong>{resource.title}</strong></div>
            <i aria-hidden="true">↗</i>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section future-home">
    <div class="shell future-home__inner">
      <div class="future-home__mark" aria-hidden="true"><span>1</span><i></i><strong>WORLD</strong></div>
      <div>
        <p class="eyebrow">Future Development Program · Published framework</p>
        <h2>Research for every dimension of life.</h2>
        <p>AUNO Center’s published development framework connects human health, animal wellbeing, earth, nature, education, and responsible innovation. No cohort, partner, venue, date, or specific project is represented as confirmed.</p>
        <p>Program initiatives will be published only when their scope, responsible people, safeguards, resources, and status are verified.</p>
        <div class="button-row"><a class="button button--primary" href="/future-development-program/">Explore the program</a><a class="button button--outline" href="/news-events/">Verified updates</a></div>
      </div>
    </div>
  </section>

  <section class="section collaboration-feature">
    <div class="shell collaboration-feature__inner">
      <div class="collaboration-feature__visual" aria-hidden="true">
        <div class="globe-rings"><i></i><i></i><i></i><span>AUNO</span></div>
      </div>
      <div>
        <p class="eyebrow">International collaboration</p>
        <h2>Research challenges cross disciplines and borders.</h2>
        <p>AUNO Center welcomes responsible collaboration with researchers, educators, healthcare teams, and institutions seeking to strengthen research capability, share methods, or develop context-sensitive initiatives.</p>
        <a class="button button--primary" href="/international-collaboration/">Explore collaboration</a>
      </div>
    </div>
  </section>

  <CallToAction title="Bring greater clarity to your next research decision." text="Tell us what you are working on, where you are in the process, and what kind of support would be most useful." />
</BaseLayout>

<style>
  .home-hero { position: relative; min-height: clamp(38rem, 75vh, 52rem); display: grid; align-items: center; overflow: hidden; color: white; background: #150d17; }
  .home-hero__image { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center; }
  .home-hero__veil { position: absolute; inset: 0; background: linear-gradient(90deg, rgba(18,8,24,.97) 0%, rgba(30,13,39,.91) 34%, rgba(28,15,30,.55) 58%, rgba(12,16,18,.22) 100%), linear-gradient(0deg, rgba(14,8,16,.45), transparent 50%); }
  .home-hero__inner { position: relative; z-index: 2; min-height: inherit; display: flex; flex-direction: column; justify-content: center; padding-block: 5rem; }
  .home-hero__copy { max-width: 46rem; }
  .home-hero h1 { max-width: 12ch; }
  .home-hero h1 em { color: #e9cc91; font-weight: 400; }
  .home-hero__copy > p:not(.eyebrow) { max-width: 43rem; margin-top: 1.5rem; color: rgba(255,255,255,.8); font-size: clamp(1.05rem, 1.7vw, 1.3rem); }
  .home-hero__signature { position: absolute; right: 0; bottom: 2.3rem; display: grid; padding: 1rem 1.2rem; text-align: right; border-right: 2px solid var(--gold); }
  .home-hero__signature span { color: rgba(255,255,255,.68); font-size: .78rem; font-weight: 700; letter-spacing: .13em; text-transform: uppercase; }
  .home-hero__signature strong { color: white; font-family: var(--font-display); font-size: 1.45rem; font-weight: 500; }
  .home-hero__signature small { margin-top:.2rem; color:var(--gold-light); font-size:.72rem; font-weight:750; letter-spacing:.08em; text-transform:uppercase; }
  .audience-band { color: white; background: var(--plum-950); border-top: 1px solid rgba(255,255,255,.13); }
  .audience-band__inner { display: grid; grid-template-columns: 18rem 1fr; align-items: center; gap: 2rem; padding-block: 1.4rem; }
  .audience-band h2 { color: var(--gold-light); font-family: var(--font-body); font-size: .74rem; font-weight: 800; letter-spacing: .12em; line-height: 1.4; text-transform: uppercase; }
  .audience-band ul { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); list-style: none; }
  .audience-band li { padding-inline: 1rem; color: rgba(255,255,255,.76); border-left: 1px solid rgba(255,255,255,.16); font-size: .8rem; line-height: 1.45; }
  .intro-grid { display: grid; grid-template-columns: minmax(0,1fr) minmax(18rem,.75fr); gap: clamp(3rem, 8vw, 8rem); }
  .intro-grid h2 { max-width: 13ch; }
  .intro-copy p + p { margin-top: 1.1rem; }
  .intro-copy .text-link { margin-top: 1.4rem; }
  .research-path { display: grid; grid-template-columns: repeat(7, auto); align-items: center; justify-content: space-between; gap: 1rem; margin-top: 5rem; padding: 1.5rem; background: var(--ivory); border: 1px solid var(--line); border-radius: var(--radius); }
  .research-path div { display: grid; }
  .research-path span { color: var(--gold-dark); font-size: .68rem; font-weight: 800; letter-spacing: .12em; }
  .research-path strong { margin-top: .6rem; font-family: var(--font-display); font-size: 1.25rem; font-weight: 500; }
  .research-path small { color: var(--ink-soft); }
  .research-path i { width: clamp(2rem, 5vw, 5rem); height: 1px; background: var(--gold); }
  .principle-grid { display: grid; grid-template-columns: repeat(4,minmax(0,1fr)); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .principle-grid article { min-height: 18rem; padding: 1.5rem; border-right: 1px solid var(--line); }
  .principle-grid article:last-child { border-right: 0; }
  .principle-grid span { width: 2.5rem; height: 2.5rem; display: grid; place-items: center; color: var(--plum-700); border: 1px solid var(--gold); border-radius: 50%; font-family: var(--font-display); font-size: 1.2rem; }
  .principle-grid h3 { margin-top: 3.5rem; font-size: 1.45rem; }
  .principle-grid p { margin-top: .7rem; font-size: .92rem; }
  .academic-home{background:linear-gradient(135deg,#f9f5ec,#f3edf5)}.academic-home__grid{display:grid;grid-template-columns:minmax(0,.8fr) minmax(22rem,1fr);gap:clamp(3rem,8vw,8rem);align-items:center}.academic-home__copy h2{max-width:14ch}.academic-home__copy>p:not(.eyebrow){max-width:42rem;margin-top:1rem}.academic-home__copy .button-row{margin-top:1.5rem}.academic-cycle{display:grid;grid-template-columns:repeat(2,1fr);list-style:none;border-top:1px solid var(--line);border-left:1px solid var(--line)}.academic-cycle li{display:grid;grid-template-columns:2rem 1fr;gap:.7rem;min-height:7.5rem;padding:1rem;border-right:1px solid var(--line);border-bottom:1px solid var(--line);background:rgba(255,255,255,.7)}.academic-cycle>li>span{color:var(--gold-dark);font-size:.62rem;font-weight:800}.academic-cycle li div{display:grid;align-content:start}.academic-cycle strong{font-family:var(--font-display);font-size:1.15rem;font-weight:500}.academic-cycle small{margin-top:.25rem;color:var(--ink-soft);line-height:1.4}
  .number-grid--dark { border-color: rgba(255,255,255,.17); }
  .number-grid--dark .number-card { background: rgba(255,255,255,.045); border-color: rgba(255,255,255,.17); }
  .number-grid--dark .number-card h3 { color: white; }
  .number-grid--dark .number-card p { color: rgba(255,255,255,.68); }
  .number-grid--dark .number-card__index { color: var(--gold-light); }
  .process-actions { justify-content: center; margin-top: 2.5rem; }
  .resource-feature { display: grid; grid-template-columns: minmax(18rem,.7fr) minmax(0,1fr); gap: clamp(3rem,8vw,8rem); align-items: start; }
  .resource-feature__intro h2 { max-width: 12ch; }
  .resource-feature__intro > p:not(.eyebrow) { margin-top: 1rem; }
  .resource-feature__intro .button { margin-top: 1.6rem; }
  .resource-feature__list { border-top: 1px solid var(--line); }
  .resource-feature__list > a { display: grid; grid-template-columns: 2rem 1fr 2rem; align-items: center; gap: 1rem; padding-block: 1.25rem; border-bottom: 1px solid var(--line); text-decoration: none; }
  .resource-feature__list > a > span { color: var(--gold-dark); font-size: .7rem; font-weight: 800; }
  .resource-feature__list small { display: block; color: var(--gold-dark); font-size: .68rem; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; }
  .resource-feature__list strong { display: block; margin-top: .25rem; font-family: var(--font-display); font-size: 1.25rem; font-weight: 500; line-height: 1.25; }
  .resource-feature__list i { width: 2rem; height: 2rem; display: grid; place-items: center; border: 1px solid var(--line); border-radius: 50%; font-style: normal; }
  .collaboration-feature__inner { display: grid; grid-template-columns: minmax(18rem,.7fr) minmax(0,1fr); align-items: center; gap: clamp(3rem,8vw,8rem); }
  .collaboration-feature h2 { max-width: 15ch; }
  .collaboration-feature p:not(.eyebrow) { max-width: 42rem; margin-top: 1.2rem; }
  .collaboration-feature .button { margin-top: 1.6rem; }
  .collaboration-feature__visual { min-height: 31rem; display: grid; place-items: center; overflow: hidden; background: radial-gradient(circle at center, #efe2f1, var(--ivory) 52%, transparent 53%); }
  .globe-rings { position: relative; width: 23rem; height: 23rem; display: grid; place-items: center; border: 1px solid var(--plum-700); border-radius: 50%; }
  .globe-rings::before, .globe-rings::after, .globe-rings i { content: ''; position: absolute; inset: 0; border: 1px solid var(--gold); border-radius: 50%; }
  .globe-rings::before { transform: scaleX(.42); }
  .globe-rings::after { transform: scaleY(.42); }
  .globe-rings i:nth-child(1) { transform: rotate(35deg) scaleX(.55); }
  .globe-rings i:nth-child(2) { transform: rotate(-35deg) scaleX(.55); }
  .globe-rings i:nth-child(3) { inset: 3rem; border-color: var(--teal); opacity: .4; }
  .globe-rings span { z-index: 1; color: var(--plum-900); font-family: var(--font-display); font-size: 2.3rem; letter-spacing: .12em; background: var(--ivory); }
  @media(max-width:61.99rem){.audience-band__inner{grid-template-columns:1fr}.audience-band ul{grid-template-columns:repeat(2,1fr);gap:.8rem 0}.intro-grid,.resource-feature,.collaboration-feature__inner,.academic-home__grid{grid-template-columns:1fr}.principle-grid{grid-template-columns:repeat(2,1fr)}.principle-grid article:nth-child(2){border-right:0}.principle-grid article:nth-child(-n+2){border-bottom:1px solid var(--line)}}
  @media(max-width:47.99rem){.home-hero{min-height:42rem}.home-hero__image{object-position:62% center}.home-hero__veil{background:linear-gradient(90deg,rgba(18,8,24,.96),rgba(28,13,36,.8) 75%,rgba(28,13,36,.6))}.home-hero__signature{display:none}.audience-band ul{grid-template-columns:1fr}.audience-band li{padding:.5rem 0;border-left:0;border-bottom:1px solid rgba(255,255,255,.13)}.research-path{grid-template-columns:1fr}.research-path i{width:1px;height:2rem;margin-left:.3rem}.principle-grid{grid-template-columns:1fr}.principle-grid article,.principle-grid article:nth-child(2){min-height:auto;border-right:0;border-bottom:1px solid var(--line)}.principle-grid article:last-child{border-bottom:0}.principle-grid h3{margin-top:2rem}.academic-cycle{grid-template-columns:1fr}.collaboration-feature__visual{min-height:22rem}.globe-rings{width:17rem;height:17rem}}
  .future-home{background:linear-gradient(135deg,#f7f1e6,#f0e8f3)}.future-home__inner{display:grid;grid-template-columns:minmax(16rem,.55fr) minmax(0,1fr);gap:clamp(3rem,8vw,8rem);align-items:center}.future-home__mark{position:relative;min-height:24rem;display:grid;place-items:center;overflow:hidden;color:white;background:linear-gradient(135deg,var(--plum-950),#164246);border-radius:50% 50% 46% 54%/43% 49% 51% 57%;box-shadow:var(--shadow-lg)}.future-home__mark:before,.future-home__mark:after{content:"";position:absolute;width:70%;height:70%;border:1px solid rgba(217,182,109,.35);border-radius:50%}.future-home__mark:after{width:48%;height:48%}.future-home__mark span{z-index:1;font-family:var(--font-display);font-size:8rem;color:var(--gold-light)}.future-home__mark i{position:absolute;width:60%;height:1px;background:rgba(255,255,255,.35)}.future-home__mark strong{position:absolute;bottom:4rem;letter-spacing:.3em;font-size:.72rem}.future-home h2{max-width:14ch}.future-home p:not(.eyebrow){max-width:47rem;margin-top:1rem}.future-home .button-row{margin-top:1.6rem}
  @media(max-width:61.99rem){.future-home__inner{grid-template-columns:1fr}.future-home__mark{min-height:20rem;max-width:28rem}}
</style>
