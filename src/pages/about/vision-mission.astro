---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import PageHero from '@/components/PageHero.astro';
import CallToAction from '@/components/CallToAction.astro';

const crumbs = [{ label: 'About', href: '/about/' }, { label: 'Vision, mission & values' }];
const objectives = [
  'Help researchers translate meaningful problems into clear and feasible research questions.',
  'Support alignment among questions, designs, data, analysis, interpretation, and reporting.',
  'Build lasting research capability through training and guided practice.',
  'Promote ethics, integrity, transparency, and responsible communication throughout the research lifecycle.',
  'Support healthcare and institutional research that responds thoughtfully to real-world needs.',
  'Encourage international knowledge exchange that respects context, contribution, and shared responsibility.',
  'Make research methods and evidence easier to understand without oversimplifying uncertainty.'
];
const values = [
  ['Integrity', 'Honesty, transparency, appropriate attribution, and responsible handling of evidence.'],
  ['Rigor', 'Methods that fit the question and conclusions that remain within the evidence.'],
  ['Respect', 'Recognition of the dignity, rights, knowledge, and context of participants and collaborators.'],
  ['Clarity', 'Accessible explanation of choices, assumptions, limitations, and next steps.'],
  ['Collaboration', 'Shared work with clear roles, expectations, and responsibility.'],
  ['Inclusion', 'Value for diverse disciplines, perspectives, experiences, and research settings.'],
  ['Learning', 'Capability that grows beyond a single deliverable.'],
  ['Accountability', 'Documented decisions, responsible reporting, and correction when needed.']
];
---

<BaseLayout title="Vision, Mission and Values | AUNO Center" description="Discover AUNO Center’s vision, mission, objectives, and values for rigorous, ethical, and collaborative research." breadcrumbs={crumbs}>
  <Breadcrumbs items={crumbs} />
  <PageHero eyebrow="Institutional foundation" title="Vision, mission & values" lead="A shared framework for strengthening research capability, responsible practice, and meaningful knowledge across disciplines and borders." tone="gold" />

  <section class="section">
    <div class="shell purpose-statements">
      <article><span>Vision</span><h2>A world in which researchers and institutions can develop credible, ethical, and useful knowledge across disciplines and borders.</h2></article>
      <article><span>Mission</span><h2>To strengthen research capability through methodological guidance, analytical support, practical education, responsible collaboration, and resources that make high-quality decisions easier to understand and apply.</h2></article>
    </div>
  </section>

  <section class="section section--ivory">
    <div class="shell content-grid">
      <div>
        <p class="eyebrow">Strategic objectives</p>
        <h2>What the center works to advance.</h2>
      </div>
      <ol class="objective-list">
        {objectives.map((objective, index) => <li><span>{String(index + 1).padStart(2, '0')}</span><p>{objective}</p></li>)}
      </ol>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section-heading"><p class="eyebrow">Our values</p><h2>Principles made visible in the work.</h2><p>These values guide how support is scoped, delivered, communicated, and reviewed.</p></div>
      <div class="values-grid">
        {values.map(([name, text], index) => <article><span>{String(index + 1).padStart(2, '0')}</span><h3>{name}</h3><p>{text}</p></article>)}
      </div>
    </div>
  </section>
  <CallToAction title="Put clear research principles into practice." text="Explore focused support for the methodological decision in front of you." />
</BaseLayout>

<style>
  .purpose-statements{display:grid;gap:1px;background:var(--line);border:1px solid var(--line)}
  .purpose-statements article{display:grid;grid-template-columns:8rem 1fr;gap:3rem;padding:clamp(2rem,5vw,4rem);background:var(--white)}
  .purpose-statements span{color:var(--gold-dark);font-size:.76rem;font-weight:800;letter-spacing:.14em;text-transform:uppercase}
  .purpose-statements h2{max-width:29ch;font-size:clamp(1.8rem,3.5vw,3rem)}
  .objective-list{list-style:none;border-top:1px solid var(--line)}
  .objective-list li{display:grid;grid-template-columns:3rem 1fr;gap:1rem;padding:1.2rem 0;border-bottom:1px solid var(--line)}
  .objective-list span{color:var(--gold-dark);font-size:.72rem;font-weight:800}.objective-list p{color:var(--ink);font-size:1.05rem}
  .values-grid{display:grid;grid-template-columns:repeat(4,1fr);border:1px solid var(--line)}
  .values-grid article{min-height:16rem;padding:1.4rem;border-right:1px solid var(--line);border-bottom:1px solid var(--line)}
  .values-grid article:nth-child(4n){border-right:0}.values-grid article:nth-last-child(-n+4){border-bottom:0}
  .values-grid span{color:var(--gold-dark);font-size:.7rem;font-weight:800}.values-grid h3{margin-top:3rem}.values-grid p{margin-top:.7rem;font-size:.9rem}
  @media(max-width:61.99rem){.values-grid{grid-template-columns:repeat(2,1fr)}.values-grid article:nth-child(2n){border-right:0}.values-grid article:nth-child(odd){border-right:1px solid var(--line)}.values-grid article:nth-last-child(-n+4){border-bottom:1px solid var(--line)}.values-grid article:nth-last-child(-n+2){border-bottom:0}}
  @media(max-width:47.99rem){.purpose-statements article{grid-template-columns:1fr;gap:1rem}.values-grid{grid-template-columns:1fr}.values-grid article,.values-grid article:nth-child(odd),.values-grid article:nth-child(2n),.values-grid article:nth-last-child(-n+2){min-height:auto;border-right:0;border-bottom:1px solid var(--line)}.values-grid article:last-child{border-bottom:0}.values-grid h3{margin-top:2rem}}
</style>
