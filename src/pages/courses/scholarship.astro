---
import BaseLayout from '@/layouts/BaseLayout.astro';import Breadcrumbs from '@/components/Breadcrumbs.astro';import PageHero from '@/components/PageHero.astro';
import FileUploadField from '@/components/FileUploadField.astro';import {courses} from '@/data/courses';const crumbs=[{label:'Courses',href:'/courses/'},{label:'Scholarship request'}];
---
<BaseLayout title="Course Scholarship Request | AUNO Center" description="Request consideration for financial support for an AUNO Center course." breadcrumbs={crumbs}><Breadcrumbs items={crumbs}/><PageHero eyebrow="Access to learning" title="Request scholarship consideration." lead="Explain the learning need, expected benefit, and financial barrier. A request is reviewed individually and does not guarantee funding or a course place." tone="gold"/><section class="section section--ivory"><div class="shell form-page-grid"><div><h2>A fair, purpose-led request.</h2><p>Share only information needed to understand your learning goal. Do not upload identity, banking, health, or other sensitive documents.</p></div><form class="form-shell" name="course-scholarship-request" method="POST" action="/thank-you/?form=scholarship" data-netlify="true" netlify-honeypot="bot-field"><input type="hidden" name="form-name" value="course-scholarship-request"/><p class="honeypot"><label>Leave empty: <input name="bot-field"/></label></p><div class="form-grid"><div class="form-field"><label for="sch-name">Full name *</label><input id="sch-name" name="full-name" required/></div><div class="form-field"><label for="sch-email">Email *</label><input id="sch-email" name="email" type="email" required/></div><div class="form-field"><label for="sch-country">Country and time zone *</label><input id="sch-country" name="country-time-zone" required/></div><div class="form-field"><label for="sch-course">Course *</label><select id="sch-course" name="course" required><option value="">Select a course</option>{courses.map(course=><option value={course.slug}>{course.title}</option>)}</select></div><div class="form-field form-field--full"><label for="sch-goal">Learning goal and expected benefit *</label><textarea id="sch-goal" name="learning-goal" required></textarea></div><div class="form-field form-field--full"><label for="sch-need">Why is financial support needed? *</label><textarea id="sch-need" name="financial-need" required></textarea></div><div class="form-field form-field--full"><label for="sch-contribution">How will you use or share the learning responsibly?</label><textarea id="sch-contribution" name="intended-contribution"></textarea></div><FileUploadField label="Scholarship evidence or supporting documents" context="AUNO Center will request any genuinely necessary evidence through an approved secure route." /></div><label class="check-row mt-2"><input name="accuracy-consent" type="checkbox" value="yes" required/><span>I confirm this request is accurate and consent to review under the <a href="/privacy/">Privacy Policy</a>. *</span></label><div class="form-actions"><p>Availability and decisions are not guaranteed.</p><button class="button button--primary" type="submit">Submit scholarship request</button></div></form></div></section></BaseLayout>
