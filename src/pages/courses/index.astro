---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import PageHero from '@/components/PageHero.astro';
import { courses } from '@/data/courses';
const crumbs = [{ label: 'Courses' }];
---
<BaseLayout title="Online Research Courses | AUNO Center" description="Accessible research-methods, statistics, evidence, ethics, writing, and responsible AI courses from AUNO Center." breadcrumbs={crumbs}>
  <Breadcrumbs items={crumbs}/>
  <PageHero eyebrow="AUNO learning portfolio" title="Research learning designed for responsible practice." lead="Focused online courses connect clear explanations with applied decisions, transparent limitations, and reusable research skills."><div slot="actions" class="button-row"><a class="button button--gold" href="/courses/enroll/">Apply to enroll</a><a class="button button--ghost-light" href="/courses/scholarship/">Request a scholarship</a></div></PageHero>
  <section class="section"><div class="shell"><div class="section-heading"><p class="eyebrow">Ten focused courses</p><h2>Build capability at the point you need it.</h2><p>Prices are displayed in USD. Enrollment, intake availability, access duration, and any payment instructions are confirmed directly before a place is final.</p></div><div class="course-grid mt-3">{courses.map(course => <article><div class="course-meta"><span>{course.category}</span><strong>${course.price} USD</strong></div><h3><a href={`/courses/${course.slug}/`}>{course.title}</a></h3><p>{course.summary}</p><div class="course-foot"><span>{course.level}</span><a class="text-link" href={`/courses/${course.slug}/`}>Course details →</a></div></article>)}</div><div class="notice mt-3"><h2>Enrollment and payment notice</h2><p>Submitting an application does not create a payment obligation or guarantee a place. AUNO Center will confirm the relevant intake, learning format, access arrangements, price, and authorised payment route before enrollment.</p></div></div></section>
</BaseLayout>
<style>.course-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1.2rem}.course-grid article{display:flex;flex-direction:column;min-height:20rem;padding:1.6rem;background:white;border:1px solid var(--line);border-radius:var(--radius)}.course-grid h3{margin-top:2rem;font-size:1.55rem}.course-grid p{margin-top:.8rem}.course-meta,.course-foot{display:flex;justify-content:space-between;gap:1rem;align-items:center}.course-meta{font-size:.72rem;text-transform:uppercase;letter-spacing:.08em}.course-meta strong{color:var(--plum-700);font-size:.9rem;white-space:nowrap}.course-foot{margin-top:auto;padding-top:1.5rem;border-top:1px solid var(--line);font-size:.78rem}.course-foot>span{color:var(--ink-soft)}@media(max-width:47.99rem){.course-grid{grid-template-columns:1fr}}</style>
