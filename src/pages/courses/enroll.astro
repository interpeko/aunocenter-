---
import BaseLayout from '@/layouts/BaseLayout.astro';import Breadcrumbs from '@/components/Breadcrumbs.astro';import PageHero from '@/components/PageHero.astro';import {courseOptions,courses} from '@/data/courses';
const crumbs=[{label:'Courses',href:'/courses/'},{label:'Enrollment application'}]; const selected=Astro.url.searchParams.get('course');
---
<BaseLayout title="Course Enrollment Application | AUNO Center" description="Apply for an AUNO Center research course." breadcrumbs={crumbs}><Breadcrumbs items={crumbs}/><PageHero eyebrow="Course enrollment" title="Begin with a clear application." lead="Tell us which course fits your learning goal. We will confirm intake availability and all enrollment details before any payment is requested." tone="gold"/><section class="section section--ivory"><div class="shell form-page-grid"><div><h2>Application, not automatic enrollment.</h2><p>Do not send payment information through this form. Prices are in USD; schedule, access, instructor, certificate status, and authorised payment instructions are confirmed in writing.</p></div><form class="form-shell" name="course-enrollment-application" method="POST" action="/thank-you/?form=course-enrollment" data-netlify="true" netlify-honeypot="bot-field"><input type="hidden" name="form-name" value="course-enrollment-application"/><p class="honeypot"><label>Leave empty: <input name="bot-field"/></label></p><fieldset class="form-section"><legend>Applicant</legend><div class="form-grid"><div class="form-field"><label for="enroll-name">Full name *</label><input id="enroll-name" name="full-name" autocomplete="name" required/></div><div class="form-field"><label for="enroll-email">Email *</label><input id="enroll-email" name="email" type="email" autocomplete="email" required/></div><div class="form-field"><label for="enroll-country">Country and time zone *</label><input id="enroll-country" name="country-time-zone" required/></div><div class="form-field"><label for="enroll-role">Current role *</label><input id="enroll-role" name="current-role" required/></div></div></fieldset><fieldset class="form-section"><legend>Learning plan</legend><div class="form-grid"><div class="form-field form-field--full"><label for="enroll-course">Course *</label><select id="enroll-course" name="course" required><option value="">Select a course</option>{courses.map((course,index)=><option value={course.slug} selected={selected===course.slug}>{courseOptions[index]}</option>)}</select></div><div class="form-field form-field--full"><label for="enroll-goal">What do you want to apply after the course? *</label><textarea id="enroll-goal" name="learning-goal" required></textarea></div><div class="form-field form-field--full"><label for="enroll-access">Accessibility or participation needs</label><textarea id="enroll-access" name="accessibility-needs"></textarea></div></div></fieldset><label class="check-row"><input name="privacy-consent" type="checkbox" value="yes" required/><span>I have read the <a href="/privacy/">Privacy Policy</a> and consent to use of this information to respond. *</span></label><div class="form-actions"><p>Do not include sensitive research, patient, or payment information.</p><button class="button button--primary" type="submit">Submit application</button></div></form></div></section></BaseLayout>
