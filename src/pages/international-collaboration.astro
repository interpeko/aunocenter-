---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import PageHero from '@/components/PageHero.astro';
const crumbs = [{ label: 'International collaboration' }];
const areas = ['Joint research-methods education','Multicountry or multisite study planning','Cross-context questionnaire adaptation','Evidence synthesis on shared priorities','Research-capacity development','Institutional research-system strengthening','Knowledge exchange and research communication','Healthcare and public-health research initiatives'];
const principles = [['Shared purpose','Begin with a clearly understood problem and intended benefit.'],['Equitable contribution','Agree roles, decisions, credit, and accountability early.'],['Contextual respect','Treat local expertise, community knowledge, and language as essential.'],['Responsible governance','Use appropriate ethics, data, legal, funding, and conflict arrangements.'],['Sustainable capability','Design collaboration to leave useful skills, systems, and relationships.'],['Transparent dissemination','Plan how findings, limitations, access, and contribution will be communicated.']];
---

<BaseLayout title="International Research Collaboration | AUNO Center" description="Explore responsible international collaboration in research methods, training, evidence synthesis, healthcare, and institutional capacity building." breadcrumbs={crumbs}>
  <Breadcrumbs items={crumbs} />
  <PageHero eyebrow="One World. One Research." title="Research collaboration across contexts." lead="Global collaboration is strongest when goals are shared, roles are explicit, local knowledge is respected, and credit and responsibility are distributed fairly.">
    <div slot="actions" class="button-row"><a class="button button--gold" href="#collaboration-inquiry">Propose a collaboration <span aria-hidden="true">↗</span></a></div>
  </PageHero>

  <section class="section"><div class="shell content-grid"><div><p class="eyebrow">Areas for collaboration</p><h2>Methods, learning, systems, and shared priorities.</h2><ul class="collaboration-areas mt-3">{areas.map((area,index)=><li><span>{String(index+1).padStart(2,'0')}</span><p>{area}</p></li>)}</ul></div><aside class="sticky-aside"><div class="side-card"><h2>A responsible first conversation</h2><p>Share the problem, intended beneficiaries, participating contexts, proposed contribution, likely partners, timeline, and funding status.</p><a href="#collaboration-inquiry">Open the inquiry form →</a></div><div class="side-card"><h2>Claims and permissions</h2><p>Partners, logos, endorsements, and active collaboration are never represented publicly without confirmation and permission.</p></div></aside></div></section>

  <section class="section section--ivory"><div class="shell"><div class="section-heading"><p class="eyebrow">Collaboration principles</p><h2>Make fairness and responsibility operational.</h2></div><div class="principles-grid">{principles.map(([title,text],index)=><article><span>{String(index+1).padStart(2,'0')}</span><h3>{title}</h3><p>{text}</p></article>)}</div></div></section>

  <section class="section" id="collaboration-inquiry"><div class="shell form-page-grid"><div><p class="eyebrow">Collaboration inquiry</p><h2>Begin with the opportunity, not a logo.</h2><p>This form is for an initial, non-confidential exploration. It does not establish a partnership, endorsement, or commitment.</p></div><form class="form-shell" name="collaboration-inquiry" method="POST" action="/thank-you/?form=collaboration" data-netlify="true" netlify-honeypot="bot-field"><input type="hidden" name="form-name" value="collaboration-inquiry"/><p class="honeypot"><label>Do not fill this out: <input name="bot-field"/></label></p>
    <fieldset class="form-section"><legend>Contact and context</legend><div class="form-grid">
      <div class="form-field"><label for="collab-name">Full name <span class="required">*</span></label><input id="collab-name" name="full-name" autocomplete="name" required/></div><div class="form-field"><label for="collab-email">Email <span class="required">*</span></label><input id="collab-email" name="email" type="email" autocomplete="email" required/></div><div class="form-field"><label for="collab-org">Institution or organisation <span class="required">*</span></label><input id="collab-org" name="institution" autocomplete="organization" required/></div><div class="form-field"><label for="collab-country">Country or region <span class="required">*</span></label><input id="collab-country" name="country-region" autocomplete="country-name" required/></div>
    </div></fieldset>
    <fieldset class="form-section"><legend>Proposed collaboration</legend><div class="form-grid">
      <div class="form-field form-field--full"><label for="collab-type">Collaboration type <span class="required">*</span></label><select id="collab-type" name="collaboration-type" required><option value="">Select one</option>{areas.map(area=><option>{area}</option>)}<option>Other</option></select></div><div class="form-field form-field--full"><label for="collab-problem">Problem or opportunity <span class="required">*</span></label><textarea id="collab-problem" name="problem-opportunity" required></textarea></div><div class="form-field form-field--full"><label for="collab-contribution">Your proposed contribution <span class="required">*</span></label><textarea id="collab-contribution" name="proposed-contribution" required></textarea></div><div class="form-field form-field--full"><label for="collab-benefit">Intended beneficiaries or value <span class="required">*</span></label><textarea id="collab-benefit" name="intended-beneficiaries" required></textarea></div><div class="form-field"><label for="collab-timeline">Indicative timeline</label><input id="collab-timeline" name="timeline"/></div><div class="form-field"><label for="collab-funding">Funding status</label><select id="collab-funding" name="funding-status"><option>Not yet identified</option><option>Application planned</option><option>Application submitted</option><option>Funding confirmed</option><option>Not applicable</option></select></div><div class="form-field form-field--full"><label for="collab-partners">Expected partners, if already confirmed</label><textarea id="collab-partners" name="expected-partners"></textarea></div>
    </div></fieldset>
    <label class="check-row mt-2" for="collab-privacy"><input id="collab-privacy" name="privacy-consent" type="checkbox" value="consent-given" required/><span>I have read the <a href="/privacy/">Privacy Policy</a> and consent to use of this information to respond. <span class="required">*</span></span></label><div class="form-actions"><p>Do not include confidential agreements, protected data, or unauthorised partner information.</p><button class="button button--primary" type="submit">Submit collaboration inquiry <span aria-hidden="true">↗</span></button></div>
  </form></div></section>
</BaseLayout>

<style>
  .collaboration-areas{list-style:none;border-top:1px solid var(--line)}.collaboration-areas li{display:grid;grid-template-columns:3rem 1fr;gap:1rem;padding:1rem 0;border-bottom:1px solid var(--line)}.collaboration-areas span{color:var(--gold-dark);font-size:.7rem;font-weight:800}.collaboration-areas p{color:var(--ink)}
  .principles-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}.principles-grid article{min-height:15rem;padding:1.5rem;background:white;border:1px solid var(--line);border-radius:var(--radius)}.principles-grid span{color:var(--gold-dark);font-size:.7rem;font-weight:800}.principles-grid h3{margin-top:3rem}.principles-grid p{margin-top:.7rem}
  .form-page-grid{display:grid;grid-template-columns:minmax(18rem,.55fr) minmax(0,1fr);gap:clamp(2rem,6vw,6rem);align-items:start}.form-page-grid>div{position:sticky;top:1rem}.form-page-grid>div h2{max-width:13ch}.form-page-grid>div>p:last-child{margin-top:1rem}
  @media(max-width:61.99rem){.form-page-grid{grid-template-columns:1fr}.form-page-grid>div{position:static}.principles-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:47.99rem){.principles-grid{grid-template-columns:1fr}}
</style>
