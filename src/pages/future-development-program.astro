---
import BaseLayout from '@/layouts/BaseLayout.astro';import Breadcrumbs from '@/components/Breadcrumbs.astro';import PageHero from '@/components/PageHero.astro';const crumbs=[{label:'Future Development Program'}];const pillars=[['Human health','Research capability and responsible evidence for healthier lives.'],['Animal wellbeing','Interdisciplinary learning that recognises animal health and welfare.'],['Earth and environment','Research approaches attentive to ecosystems, climate, resources, and place.'],['Education and innovation','Accessible learning, responsible technology, and exchange across fields.']];
---
<BaseLayout title="Future Development Program | AUNO Center" description="AUNO Center’s published interdisciplinary development framework connects human health, animal wellbeing, environment, education, and responsible innovation." breadcrumbs={crumbs}><Breadcrumbs items={crumbs}/><PageHero eyebrow="Published development framework" title="Research for every dimension of life." lead="The Future Development Program records the Center’s direction for multidisciplinary learning, responsible innovation, scientific collaboration, and sustainable development; it is not presented as an active project portfolio."/><section class="section"><div class="shell"><div class="section-heading"><p class="eyebrow">Program direction</p><h2>One world requires connected research.</h2><p>Human beings, animals, the earth, and nature are deeply interconnected. The published framework provides a basis for developing future education, collaboration, and research-support initiatives that respect those connections.</p></div><div class="number-grid mt-3">{pillars.map((pillar,index)=><article class="number-card"><span class="number-card__index">{String(index+1).padStart(2,'0')}</span><h3>{pillar[0]}</h3><p>{pillar[1]}</p></article>)}</div></div></section><section class="section section--plum"><div class="shell content-grid"><div class="section-heading section-heading--light"><p class="eyebrow eyebrow--light">Responsible development</p><h2>From ambition to evidence-backed programs.</h2><p>Each future initiative will be scoped around a defined need, responsible roles, ethics and safeguarding, measurable learning or research outcomes, feasible resources, and transparent reporting.</p></div><div class="side-card"><h2>Current public status</h2><p>The development direction is published; no specific cohort, partner, venue, date, funded program, or research project is represented as confirmed on this page.</p><a class="text-link mt-1" href="/international-collaboration/">Explore collaboration <span class="icon icon--right" aria-hidden="true"></span></a></div></div></section><section class="section"><div class="shell"><div class="section-heading"><p class="eyebrow">Program media</p><h2>A verified gallery will follow.</h2><p>Program photographs have not yet been supplied for publication. This space will display real, captioned, permission-cleared images when the Center provides them; no stock imagery is presented as documentary evidence.</p></div></div></section></BaseLayout>
