---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import PageHero from '@/components/PageHero.astro';
import { socials } from '@/data/site';

const crumbs = [{ label: 'Media & YouTube' }];
const youtube = socials.find((item) => item.icon === 'youtube');
const downloads = [
  {
    title: 'Production brief & storyboard',
    type: 'Markdown',
    size: '2.8 KB',
    description: 'Master narrative, social adaptations, storyboard guidance, accessibility notes, and the publication checklist.',
    href: '/media/auno-center-introduction-production-brief.md'
  },
  {
    title: 'English voiceover transcript',
    type: 'Plain text',
    size: '1 KB',
    description: 'The English narration in an accessible plain-text format for review, editing, and publication.',
    href: '/media/auno-center-introduction-transcript.txt'
  },
  {
    title: 'Timed English captions',
    type: 'WebVTT',
    size: '1 KB',
    description: 'Timed English captions prepared for the proposed institutional introduction video.',
    href: '/media/auno-center-introduction-captions.vtt'
  },
  {
    title: 'High-resolution video thumbnail',
    type: 'SVG image',
    size: '1.8 KB',
    description: 'Scalable 16:9 artwork for the AUNO Center institutional introduction package.',
    href: '/images/auno-introduction-thumbnail.svg',
    thumbnail: '/images/auno-introduction-thumbnail.svg'
  }
];
---

<BaseLayout title="Media and YouTube | AUNO Center" description="Official AUNO Center YouTube channel, institutional media information, and a complete English introductory-video production package." breadcrumbs={crumbs}>
  <Breadcrumbs items={crumbs} />
  <PageHero eyebrow="Institutional media" title="Ideas communicated with accuracy and purpose." lead="Visit the official YouTube channel or use the publication-ready English introduction package, including scripts, storyboard, captions, transcript, and thumbnail.">
    <div slot="actions" class="button-row">
      <a class="button button--gold" href={youtube?.href} target="_blank" rel="noopener noreferrer">
        Visit AUNO Center on YouTube
        <span class="visually-hidden"> (opens in a new tab)</span>
        <span class="icon icon--up-right" aria-hidden="true"></span>
      </a>
      <a class="button button--ghost-light" href="/contact/#general-contact">Media enquiry</a>
    </div>
  </PageHero>

  <section class="section">
    <div class="shell content-grid">
      <div>
        <p class="eyebrow">Official channel</p>
        <h2>@aunocenter on YouTube.</h2>
        <p class="mt-1">The channel is the official destination for verified research education, institutional introductions, public learning, and responsible scientific communication. No individual video is listed until its public URL and publication details are verified.</p>
        <div class="media-principles mt-3">
          <article><span>01</span><h3>Accurate</h3><p>Claims and sources are reviewable.</p></article>
          <article><span>02</span><h3>Accessible</h3><p>Plain language, captions, transcripts, and clear visuals.</p></article>
          <article><span>03</span><h3>Responsible</h3><p>No diagnosis, guaranteed outcomes, or misleading certainty.</p></article>
        </div>
      </div>
      <aside class="sticky-aside">
        <div class="side-card"><h2>Institutional description</h2><p>AUNO Center is an interdisciplinary global research center connecting medicine, surgery, research, education, innovation, human health, animal health, earth, nature, and the environment.</p></div>
        <div class="side-card"><h2>Editorial notice</h2><p>Media is educational and does not replace clinical, legal, ethics, regulatory, or project-specific professional advice.</p></div>
      </aside>
    </div>
  </section>

  <section class="section section--ivory">
    <div class="shell">
      <div class="section-heading">
        <p class="eyebrow">Introductory video package</p>
        <h2>Ready for ethical production and publication.</h2>
        <p>The package includes a 60-second master narrative, 30- and 15-second social adaptations, shot guidance, on-screen text, voiceover, caption timing, accessibility notes, and a scalable thumbnail. It is a production package—not a claim that a video has already been published.</p>
      </div>

      <div class="download-grid mt-3">
        {downloads.map((item) => (
          <article class="media-file">
            <div class="media-file__preview" aria-hidden="true">
              {item.thumbnail ? (
                <img src={item.thumbnail} width="1920" height="1080" alt="" loading="lazy" decoding="async" />
              ) : (
                <span class="media-file__document"><span class="icon icon--file"></span></span>
              )}
            </div>
            <div class="media-file__body">
              <div class="media-file__meta"><span>{item.type}</span><span>{item.size}</span></div>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
              <div class="media-file__actions">
                <a class="button button--outline" href={item.href} target="_blank" rel="noopener noreferrer">
                  View
                  <span class="visually-hidden"> {item.title} (opens in a new tab)</span>
                  <span class="icon icon--eye" aria-hidden="true"></span>
                </a>
                <a class="button button--outline" href={item.href} download>
                  Download
                  <span class="visually-hidden"> {item.title}</span>
                  <span class="icon icon--download" aria-hidden="true"></span>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="notice mt-3"><h2>Publication checkpoint</h2><p>Before upload, confirm consent and licensing for every person, image, clip, voice, music track, logo, and research claim. Add final captions and a transcript, review pronunciation, and preserve the consultancy disclaimer.</p></div>
    </div>
  </section>
</BaseLayout>

<style>
  .media-principles{display:grid;grid-template-columns:repeat(3,1fr);overflow:hidden;border:1px solid var(--line);border-radius:var(--radius);background:var(--white)}
  .media-principles article{padding:1.35rem;border-right:1px solid var(--line)}
  .media-principles article:last-child{border:0}
  .media-principles span,.media-file__meta{font-size:.75rem;color:var(--gold-dark);font-weight:800;text-transform:uppercase;letter-spacing:.07em}
  .media-principles h3{margin-top:2rem}
  .download-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1rem}
  .media-file{display:grid;grid-template-columns:minmax(10rem,.72fr) minmax(0,1fr);min-height:18rem;overflow:hidden;background:var(--white);border:1px solid var(--line);border-radius:var(--radius-lg);box-shadow:0 10px 30px rgba(31,13,41,.045);transition:border-color .25s var(--ease-premium),transform .25s var(--ease-premium),box-shadow .25s var(--ease-premium)}
  .media-file:hover{border-color:rgba(116,80,13,.38);transform:translateY(-2px);box-shadow:0 16px 38px rgba(31,13,41,.07)}
  .media-file__preview{display:grid;min-height:100%;place-items:center;overflow:hidden;background:var(--plum-50);border-right:1px solid var(--line)}
  .media-file__preview img{width:100%;height:100%;min-height:10rem;object-fit:contain}
  .media-file__document{display:grid;width:4.3rem;height:4.3rem;place-items:center;color:var(--plum-700);background:var(--white);border:1px solid rgba(82,36,94,.12);border-radius:1.15rem;box-shadow:0 8px 22px rgba(31,13,41,.07)}
  .media-file__document .icon{width:1.7rem;height:1.7rem}
  .media-file__body{display:flex;min-width:0;flex-direction:column;padding:1.5rem}
  .media-file__meta{display:flex;flex-wrap:wrap;gap:.55rem 1rem}
  .media-file h3{margin-top:1.6rem;font-size:1.45rem}
  .media-file p{margin-top:.75rem;font-size:.9rem}
  .media-file__actions{display:flex;flex-wrap:wrap;gap:.55rem;margin-top:auto;padding-top:1.4rem}
  .media-file__actions .button{min-height:2.75rem;padding:.6rem .82rem;font-size:.78rem}
  @media(max-width:61.99rem){.download-grid{grid-template-columns:1fr}}
  @media(max-width:47.99rem){.media-principles{grid-template-columns:1fr}.media-principles article{border-right:0;border-bottom:1px solid var(--line)}.media-file{grid-template-columns:1fr}.media-file__preview{min-height:10.5rem;border-right:0;border-bottom:1px solid var(--line)}.media-file__preview img{max-height:14rem}.media-file__actions .button{flex:1}}
  @media(prefers-reduced-motion:reduce){.media-file:hover{transform:none}}
</style>
