---
import BaseLayout from '@/layouts/BaseLayout.astro';import Breadcrumbs from '@/components/Breadcrumbs.astro';import PageHero from '@/components/PageHero.astro';import {socials} from '@/data/site';const crumbs=[{label:'Media & YouTube'}];const youtube=socials.find(item=>item.icon==='youtube');
---
<BaseLayout title="Media and YouTube | AUNO Center" description="Official AUNO Center media, video channel, institutional profile, and publication-ready media information." breadcrumbs={crumbs}><Breadcrumbs items={crumbs}/><PageHero eyebrow="Institutional media" title="Ideas communicated with accuracy and purpose." lead="Find the official AUNO Center YouTube channel, institutional profile, media contact route, and the standards used before media is published."><div slot="actions" class="button-row"><a class="button button--gold" href={youtube?.href} target="_blank" rel="noopener">Visit AUNO Center on YouTube ↗</a><a class="button button--ghost-light" href="/contact/#general-contact">Media enquiry</a></div></PageHero><section class="section"><div class="shell content-grid"><div><p class="eyebrow">Official channel</p><h2>@aunocenter on YouTube.</h2><p class="mt-1">The channel is the official destination for future research education, institutional introductions, public learning, and responsible scientific communication. No individual video is listed until its public URL and details are verified.</p><div class="media-principles mt-3"><article><span>01</span><h3>Accurate</h3><p>Claims and sources should be reviewable.</p></article><article><span>02</span><h3>Accessible</h3><p>Plain language, captions, transcripts, and clear visuals.</p></article><article><span>03</span><h3>Responsible</h3><p>No diagnosis, guaranteed outcomes, or misleading certainty.</p></article></div></div><aside class="sticky-aside"><div class="side-card"><h2>Institutional description</h2><p>AUNO Center is an interdisciplinary global research center connecting medicine, surgery, research, education, innovation, human health, animal health, earth, nature, and the environment.</p></div><div class="side-card"><h2>Editorial notice</h2><p>Media is educational and does not replace clinical, legal, ethics, regulatory, or project-specific professional advice.</p></div></aside></div></section></BaseLayout><style>.media-principles{display:grid;grid-template-columns:repeat(3,1fr);border:1px solid var(--line)}.media-principles article{padding:1.2rem;border-right:1px solid var(--line)}.media-principles article:last-child{border:0}.media-principles span{font-size:.7rem;color:var(--gold-dark);font-weight:800}.media-principles h3{margin-top:2rem}@media(max-width:47.99rem){.media-principles{grid-template-columns:1fr}.media-principles article{border-right:0;border-bottom:1px solid var(--line)}}</style>
