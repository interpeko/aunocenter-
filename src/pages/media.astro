---
import BaseLayout from '@/layouts/BaseLayout.astro';import Breadcrumbs from '@/components/Breadcrumbs.astro';import PageHero from '@/components/PageHero.astro';import {socials} from '@/data/site';const crumbs=[{label:'Media & YouTube'}];const youtube=socials.find(item=>item.icon==='youtube');
const downloads=[
  {title:'Production brief & storyboard',type:'Markdown',href:'/media/auno-center-introduction-production-brief.md'},
  {title:'English voiceover transcript',type:'Plain text',href:'/media/auno-center-introduction-transcript.txt'},
  {title:'Timed English captions',type:'WebVTT',href:'/media/auno-center-introduction-captions.vtt'},
  {title:'High-resolution video thumbnail',type:'SVG',href:'/images/auno-introduction-thumbnail.svg'}
];
---
<BaseLayout title="Media and YouTube | AUNO Center" description="Official AUNO Center YouTube channel, institutional media information, and a complete English introductory-video production package." breadcrumbs={crumbs}><Breadcrumbs items={crumbs}/><PageHero eyebrow="Institutional media" title="Ideas communicated with accuracy and purpose." lead="Visit the official YouTube channel or use the publication-ready English introduction package, including scripts, storyboard, captions, transcript, and thumbnail."><div slot="actions" class="button-row"><a class="button button--gold" href={youtube?.href} target="_blank" rel="noopener">Visit AUNO Center on YouTube ↗</a><a class="button button--ghost-light" href="/contact/#general-contact">Media enquiry</a></div></PageHero>
<section class="section"><div class="shell content-grid"><div><p class="eyebrow">Official channel</p><h2>@aunocenter on YouTube.</h2><p class="mt-1">The channel is the official destination for verified research education, institutional introductions, public learning, and responsible scientific communication. No individual video is listed until its public URL and publication details are verified.</p><div class="media-principles mt-3"><article><span>01</span><h3>Accurate</h3><p>Claims and sources are reviewable.</p></article><article><span>02</span><h3>Accessible</h3><p>Plain language, captions, transcripts, and clear visuals.</p></article><article><span>03</span><h3>Responsible</h3><p>No diagnosis, guaranteed outcomes, or misleading certainty.</p></article></div></div><aside class="sticky-aside"><div class="side-card"><h2>Institutional description</h2><p>AUNO Center is an interdisciplinary global research center connecting medicine, surgery, research, education, innovation, human health, animal health, earth, nature, and the environment.</p></div><div class="side-card"><h2>Editorial notice</h2><p>Media is educational and does not replace clinical, legal, ethics, regulatory, or project-specific professional advice.</p></div></aside></div></section>
<section class="section section--ivory"><div class="shell"><div class="section-heading"><p class="eyebrow">Introductory video package</p><h2>Ready for ethical production and publication.</h2><p>The package includes a 60-second master narrative, 30- and 15-second social adaptations, shot guidance, on-screen text, voiceover, caption timing, accessibility notes, and a scalable thumbnail. It is a production package—not a claim that a video has already been published.</p></div><div class="download-grid mt-3">{downloads.map(item=><article><span>{item.type}</span><h3>{item.title}</h3><a class="button button--outline" href={item.href} download>Download</a></article>)}</div><div class="notice mt-3"><h2>Publication checkpoint</h2><p>Before upload, confirm consent and licensing for every person, image, clip, voice, music track, logo, and research claim. Add final captions and a transcript, review pronunciation, and preserve the consultancy disclaimer.</p></div></div></section></BaseLayout>
<style>.media-principles{display:grid;grid-template-columns:repeat(3,1fr);border:1px solid var(--line)}.media-principles article{padding:1.2rem;border-right:1px solid var(--line)}.media-principles article:last-child{border:0}.media-principles span,.download-grid span{font-size:.7rem;color:var(--gold-dark);font-weight:800;text-transform:uppercase;letter-spacing:.08em}.media-principles h3{margin-top:2rem}.download-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem}.download-grid article{display:flex;min-height:14rem;flex-direction:column;padding:1.3rem;background:white;border:1px solid var(--line);border-radius:var(--radius)}.download-grid h3{margin-top:2rem;font-size:1.25rem}.download-grid .button{margin-top:auto}@media(max-width:61.99rem){.download-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:47.99rem){.media-principles,.download-grid{grid-template-columns:1fr}.media-principles article{border-right:0;border-bottom:1px solid var(--line)}}</style>
