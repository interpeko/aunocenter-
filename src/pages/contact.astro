---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import PageHero from '@/components/PageHero.astro';
import SocialIcon from '@/components/SocialIcon.astro';
import { SITE, socials } from '@/data/site';
const crumbs = [{ label: 'Contact' }];
const contactSchema = {
  '@context': 'https://schema.org', '@type': 'ContactPage', name: 'Contact AUNO Center',
  url: new URL('/contact/', Astro.site ?? Astro.url.origin).href
};
---

<BaseLayout title="Contact AUNO Center" description="Contact AUNO Center about research support, training, institutional work, international collaboration, media, and general enquiries." breadcrumbs={crumbs} schema={contactSchema}>
  <Breadcrumbs items={crumbs} />
  <PageHero eyebrow="Contact AUNO Center" title="Choose the route that fits your enquiry." lead="For a research project, the dedicated support portal gathers the information needed for an initial review. For everything else, use the form or official channels below.">
    <div slot="actions" class="button-row"><a class="button button--gold" href="/request-support/">Request research support <span class="icon icon--up-right" aria-hidden="true"></span></a><a class="button button--ghost-light" href={`mailto:${SITE.email}`}>Email AUNO Center</a></div>
  </PageHero>

  <section class="section section--ivory">
    <div class="shell route-grid">
      <article><span>01</span><h2>Research project</h2><p>Methodology, statistics, questionnaires, interpretation, manuscripts, or evidence synthesis.</p><a class="text-link" href="/request-support/">Open the support portal <span class="icon icon--right" aria-hidden="true"></span></a></article>
      <article><span>02</span><h2>Training programme</h2><p>Workshops, seminars, project clinics, short courses, and tailored institutional learning.</p><a class="text-link" href="/training/#training-inquiry">Request training <span class="icon icon--right" aria-hidden="true"></span></a></article>
      <article><span>03</span><h2>International collaboration</h2><p>Responsible methods education, evidence projects, healthcare research, and capability building.</p><a class="text-link" href="/international-collaboration/#collaboration-inquiry">Propose collaboration <span class="icon icon--right" aria-hidden="true"></span></a></article>
      <article><span>04</span><h2>General enquiry</h2><p>Media, speaking, accessibility, privacy, website feedback, or another institutional question.</p><a class="text-link" href="#general-contact">Use the contact form <span class="icon icon--right" aria-hidden="true"></span></a></article>
    </div>
  </section>

  <section class="section">
    <div class="shell contact-grid">
      <div>
        <p class="eyebrow">Official channels</p><h2>Connect with AUNO Center.</h2>
        <p class="max-copy mt-1">Follow research resources, confirmed events, and institutional announcements through the official channels below. External links open in a new tab.</p>
        <p class="mt-1"><strong>Telephone:</strong> <a href={`tel:${SITE.phone.replace(/[^+\d]/g, '')}`}>{SITE.phone}</a></p>
        <div class="social-list mt-2">
          {socials.map((social) => <a class="social-card" style={`--social-color:${social.color}`} href={social.href} target={social.icon === 'gmail' ? undefined : '_blank'} rel={social.icon === 'gmail' ? undefined : 'noopener noreferrer'}><span class="social-card__icon"><SocialIcon icon={social.icon} size={21}/></span><span><strong>{social.name}</strong><small>{social.handle}</small></span></a>)}
        </div>
      </div>
      <aside class="poster-card" aria-labelledby="social-poster-title">
        <div class="poster-card__media">
          <img src="/images/auno-social-poster-preview.webp" width="720" height="900" alt="AUNO Center social poster listing its official communication channels" loading="lazy" decoding="async" />
        </div>
        <div class="poster-card__body">
          <p class="eyebrow">Share the network</p>
          <h2 id="social-poster-title">One World. One Research.</h2>
          <p>A high-resolution poster bringing every official AUNO Center channel together.</p>
          <div class="poster-card__meta" aria-label="Poster file formats"><span>PNG image</span><span>Scalable SVG</span></div>
          <div class="button-row poster-card__actions">
            <a class="button button--outline" href="/images/auno-social-poster.png" target="_blank" rel="noopener noreferrer">
              View poster
              <span class="visually-hidden"> (opens in a new tab)</span>
              <span class="icon icon--eye" aria-hidden="true"></span>
            </a>
            <a class="button button--outline" href="/images/auno-social-poster.png" download>
              Download PNG
              <span class="icon icon--download" aria-hidden="true"></span>
            </a>
            <a class="button button--outline" href="/images/auno-social-poster.svg" download>
              Download SVG
              <span class="icon icon--download" aria-hidden="true"></span>
            </a>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section section--ivory" id="general-contact">
    <div class="shell form-page-grid">
      <div><p class="eyebrow">General contact</p><h2>Send a clear, non-confidential message.</h2><p>Messages are reviewed through the email address you provide. A time-sensitive deadline is not confirmed until you receive a direct response.</p><div class="notice mt-2"><p>Do not submit sensitive patient or participant data, credentials, private institutional records, or confidential datasets.</p></div></div>
      <form class="form-shell" name="general-contact" method="POST" action="/thank-you/?form=contact" data-netlify="true" netlify-honeypot="bot-field">
        <input type="hidden" name="form-name" value="general-contact"/><p class="honeypot"><label>Do not fill this out: <input name="bot-field"/></label></p>
        <fieldset class="form-section"><legend>Your details</legend><div class="form-grid">
          <div class="form-field"><label for="contact-name">Full name <span class="required">*</span></label><input id="contact-name" name="full-name" autocomplete="name" required/></div><div class="form-field"><label for="contact-email">Email <span class="required">*</span></label><input id="contact-email" name="email" type="email" autocomplete="email" required/></div><div class="form-field"><label for="contact-org">Organisation</label><input id="contact-org" name="organisation" autocomplete="organization"/></div><div class="form-field"><label for="contact-country">Country or time zone</label><input id="contact-country" name="country-time-zone"/></div>
        </div></fieldset>
        <fieldset class="form-section"><legend>Your message</legend><div class="form-grid">
          <div class="form-field"><label for="contact-type">Enquiry type <span class="required">*</span></label><select id="contact-type" name="enquiry-type" required><option value="">Select one</option><option>General</option><option>Research support</option><option>Training</option><option>Institutional support</option><option>Collaboration</option><option>Media or speaking</option><option>Accessibility</option><option>Privacy</option><option>Other</option></select></div><div class="form-field"><label for="reply-method">Preferred reply method</label><select id="reply-method" name="preferred-reply-method"><option>Email</option><option>WhatsApp</option><option>Telegram</option></select></div><div class="form-field form-field--full"><label for="contact-subject">Subject <span class="required">*</span></label><input id="contact-subject" name="subject" required/></div><div class="form-field form-field--full"><label for="contact-message">Message <span class="required">*</span></label><textarea id="contact-message" name="message" minlength="20" required></textarea></div>
        </div></fieldset>
        <label class="check-row mt-2" for="contact-privacy"><input id="contact-privacy" name="privacy-consent" type="checkbox" value="consent-given" required/><span>I have read the <a href="/privacy/">Privacy Policy</a> and consent to use of this information to respond. <span class="required">*</span></span></label>
        <div class="form-actions"><p>Submitting this form does not create a consultancy relationship or confirm availability.</p><button class="button button--primary" type="submit">Send message <span class="icon icon--up-right" aria-hidden="true"></span></button></div>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .route-grid{display:grid;grid-template-columns:repeat(4,1fr);border:1px solid var(--line);background:white}.route-grid article{min-height:19rem;padding:1.5rem;border-right:1px solid var(--line)}.route-grid article:last-child{border-right:0}.route-grid>article>span{color:var(--gold-dark);font-size:.7rem;font-weight:800}.route-grid h2{margin-top:3.5rem;font-size:1.55rem}.route-grid p{margin-top:.7rem;font-size:.9rem}.route-grid .text-link{margin-top:1.2rem;font-size:.84rem}
  .contact-grid{display:grid;grid-template-columns:minmax(0,1fr) minmax(20rem,.62fr);gap:clamp(3rem,7vw,7rem)}.poster-card{align-self:start;overflow:hidden;background:var(--white);border:1px solid var(--line);border-radius:var(--radius-lg);box-shadow:0 12px 36px rgba(31,13,41,.06)}.poster-card__media{display:grid;aspect-ratio:4/5;place-items:center;overflow:hidden;padding:clamp(.65rem,2vw,1rem);background:var(--plum-50);border-bottom:1px solid var(--line)}.poster-card__media img{width:100%;height:100%;object-fit:contain;border-radius:calc(var(--radius) - .25rem);box-shadow:0 8px 24px rgba(31,13,41,.07)}.poster-card__body{padding:1.6rem}.poster-card h2{font-size:1.6rem}.poster-card p:not(.eyebrow){margin-top:.7rem}.poster-card__meta{display:flex;flex-wrap:wrap;gap:.45rem 1rem;margin-top:1rem;color:var(--gold-dark);font-size:.75rem;font-weight:800;letter-spacing:.07em;text-transform:uppercase}.poster-card__actions{gap:.55rem;margin-top:1.35rem}.poster-card__actions .button{min-height:2.75rem;padding:.6rem .78rem;font-size:.78rem}
  .form-page-grid{display:grid;grid-template-columns:minmax(18rem,.55fr) minmax(0,1fr);gap:clamp(2rem,6vw,6rem);align-items:start}.form-page-grid>div{position:sticky;top:1rem}.form-page-grid>div h2{max-width:13ch}.form-page-grid>div>p{margin-top:1rem}
  @media(max-width:61.99rem){.route-grid{grid-template-columns:repeat(2,1fr)}.route-grid article:nth-child(2){border-right:0}.route-grid article:nth-child(-n+2){border-bottom:1px solid var(--line)}.contact-grid,.form-page-grid{grid-template-columns:1fr}.form-page-grid>div{position:static}.poster-card{max-width:30rem}}
  @media(max-width:47.99rem){.route-grid{grid-template-columns:1fr}.route-grid article,.route-grid article:nth-child(2){min-height:auto;border-right:0;border-bottom:1px solid var(--line)}.route-grid article:last-child{border-bottom:0}.route-grid h2{margin-top:2rem}}
</style>
