---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import PageHero from '@/components/PageHero.astro';
import { publicContentRegistry } from '../../shared/public-content-registry.mjs';
const crumbs = [{ label: 'Search' }];
const pages = publicContentRegistry.map(record => ({ title: record.title, type: record.type, description: record.excerpt, href: record.href }));
---

<BaseLayout title="Search | AUNO Center" description="Search AUNO Center services, research resources, training, focus areas, and institutional information." breadcrumbs={crumbs} noindex>
  <Breadcrumbs items={crumbs} /><PageHero eyebrow="Site search" title="Find research support and knowledge." lead="Search services, resources, institutional pages, training, and research focus areas." tone="light" />
  <section class="section"><div class="shell search-layout"><div class="site-search"><label for="site-search">Search AUNO Center</label><div><span class="site-search__input"><span class="icon icon--search" aria-hidden="true"></span><input id="site-search" type="search" placeholder="Try “questionnaire”, “ethics”, or “healthcare”" autofocus/></span><button class="button button--primary" type="button" id="search-button">Search <span class="icon icon--right" aria-hidden="true"></span></button></div></div><p id="search-status" role="status" aria-live="polite">Enter a topic to search {pages.length} pages and resources.</p><div class="search-suggestions" id="search-suggestions"><p>Popular routes</p><div><a href="/services/">Research services</a><a href="/request-support/">Support portal</a><a href="/resources/">Resource library</a><a href="/courses/">Courses</a><a href="/research-ethics-integrity/">Ethics & integrity</a><a href="/interpeko/">Ask Interpeko</a></div></div><section class="saved-results recent-results" id="recent-results" hidden aria-labelledby="recent-title"><div><div><p class="eyebrow">Recently viewed on this device</p><h2 id="recent-title">Continue exploring</h2></div><button type="button" id="clear-recent">Clear history</button></div><ul id="recent-list"></ul><p class="local-note">This browsing list stays in this browser and is never submitted to AUNO Center.</p></section><section class="saved-results" id="saved-results" hidden aria-labelledby="saved-title"><div><div><p class="eyebrow">Saved on this device</p><h2 id="saved-title">Your saved routes</h2></div><button type="button" id="clear-saved">Clear saved items</button></div><ul id="saved-list"></ul></section><div class="search-results" id="search-results">{pages.map(page=><article data-search={`${page.title} ${page.type} ${page.description}`.toLowerCase()} data-title={page.title.toLowerCase()} data-page-title={page.title} data-page-href={page.href} hidden><div class="search-result__meta"><span>{page.type}</span><button type="button" data-save aria-label={`Save ${page.title} on this device`}>Save</button></div><h2><a href={page.href}>{page.title}</a></h2><p>{page.description}</p></article>)}</div></div></section>
</BaseLayout>

<script>
  const input=document.querySelector<HTMLInputElement>('#site-search');const button=document.querySelector<HTMLButtonElement>('#search-button');const results=[...document.querySelectorAll<HTMLElement>('[data-search]')];const status=document.querySelector<HTMLElement>('#search-status');const suggestions=document.querySelector<HTMLElement>('#search-suggestions');const savedSection=document.querySelector<HTMLElement>('#saved-results');const savedList=document.querySelector<HTMLUListElement>('#saved-list');const clearSaved=document.querySelector<HTMLButtonElement>('#clear-saved');const recentSection=document.querySelector<HTMLElement>('#recent-results');const recentList=document.querySelector<HTMLUListElement>('#recent-list');const clearRecent=document.querySelector<HTMLButtonElement>('#clear-recent');
  const storageKey='auno-saved-routes';type SavedRoute={title:string;href:string};
  const repositoryBase=location.hostname.endsWith('github.io')?'/aunocenter-':'';const siteHref=(href:string)=>href.startsWith('/')&&!href.startsWith(`${repositoryBase}/`)?`${repositoryBase}${href}`:href;
  function getSaved():SavedRoute[]{try{return JSON.parse(localStorage.getItem(storageKey)||'[]').filter((item:SavedRoute)=>item?.title&&item?.href).slice(0,12)}catch{return[]}}
  function setSaved(items:SavedRoute[]){try{localStorage.setItem(storageKey,JSON.stringify(items.slice(0,12)))}catch{}renderSaved()}
  function renderSaved(){const items=getSaved();if(savedSection)savedSection.hidden=items.length===0;if(savedList){savedList.replaceChildren(...items.map(item=>{const li=document.createElement('li');const a=document.createElement('a');a.href=siteHref(item.href);a.textContent=item.title;const remove=document.createElement('button');remove.type='button';remove.textContent='Remove';remove.setAttribute('aria-label',`Remove ${item.title} from saved routes`);remove.addEventListener('click',()=>setSaved(getSaved().filter(saved=>saved.href!==item.href)));li.append(a,remove);return li}))}document.querySelectorAll<HTMLButtonElement>('[data-save]').forEach(save=>{const card=save.closest<HTMLElement>('[data-page-href]');const active=getSaved().some(item=>item.href===card?.dataset.pageHref);save.textContent=active?'Saved':'Save';save.setAttribute('aria-pressed',String(active))})}
  function renderRecent(){let items:SavedRoute[]=[];try{items=JSON.parse(localStorage.getItem('auno-recent-pages')||'[]').filter((item:SavedRoute)=>item?.title&&item?.href).slice(0,6)}catch{}if(recentSection)recentSection.hidden=items.length===0;if(recentList)recentList.replaceChildren(...items.map(item=>{const li=document.createElement('li');const a=document.createElement('a');a.href=item.href;a.textContent=item.title;li.append(a);return li}))}
  function run(){const q=input?.value.toLowerCase().trim()??'';const terms=q.split(/\s+/).filter(term=>term.length>1);let count=0;const ranked=results.map(item=>{const haystack=item.dataset.search||'';const title=item.dataset.title||'';const score=terms.reduce((total,term)=>total+(title.startsWith(term)?6:title.includes(term)?4:haystack.includes(term)?1:0),0);const show=terms.length>0&&terms.every(term=>haystack.includes(term));item.hidden=!show;if(show)count++;return{item,score}}).sort((a,b)=>b.score-a.score);const container=document.querySelector('#search-results');ranked.forEach(({item})=>container?.append(item));if(suggestions)suggestions.hidden=q.length>0;if(status)status.textContent=q?`${count} ${count===1?'result':'results'} for “${input?.value.trim()}”.`:`Enter a topic to search ${results.length} pages and resources.`}
  results.forEach(card=>card.querySelector<HTMLButtonElement>('[data-save]')?.addEventListener('click',()=>{const item={title:card.dataset.pageTitle||'',href:card.dataset.pageHref||''};const current=getSaved();setSaved(current.some(saved=>saved.href===item.href)?current.filter(saved=>saved.href!==item.href):[item,...current])}));clearSaved?.addEventListener('click',()=>setSaved([]));
  clearRecent?.addEventListener('click',()=>{try{localStorage.removeItem('auno-recent-pages')}catch{}renderRecent()});input?.addEventListener('input',run);input?.addEventListener('keydown',event=>{if(event.key==='Enter')run()});button?.addEventListener('click',run);renderSaved();renderRecent();const q=new URLSearchParams(location.search).get('q');if(input&&q){input.value=q;run()}
</script>

<style>
  .search-layout{max-width:58rem}.site-search label{display:block;margin-bottom:.5rem;font-weight:750}.site-search>div{display:grid;grid-template-columns:1fr auto;gap:.6rem}.site-search__input{display:flex;align-items:center;gap:.7rem;padding:0 .9rem;background:var(--white);border:1px solid #cfc6d1;border-radius:.78rem;transition:border-color .25s var(--ease-premium),box-shadow .25s var(--ease-premium)}.site-search__input:focus-within{border-color:var(--plum-700);box-shadow:0 0 0 3px rgba(82,36,94,.1)}.site-search__input>.icon{color:var(--plum-700)}.site-search input{width:100%;min-height:3.25rem;padding:.75rem 0;background:transparent;border:0;outline:0}.search-layout>p{margin-top:1rem;font-size:.84rem}.search-suggestions{margin-top:2rem;padding:1.3rem;background:var(--ivory);border:1px solid var(--line);border-radius:var(--radius)}.search-suggestions>p{color:var(--gold-dark);font-size:.75rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase}.search-suggestions>div{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:.75rem}.search-suggestions a{padding:.5rem .72rem;background:var(--white);border:1px solid var(--line);border-radius:999px;color:var(--plum-700);font-size:.8rem;font-weight:750;text-decoration:none}.search-suggestions a:hover{border-color:var(--gold)}.saved-results{margin-top:2rem;padding:1.3rem;border:1px solid var(--line);border-radius:var(--radius)}.recent-results{background:#faf8fb}.saved-results>div{display:flex;align-items:end;justify-content:space-between;gap:1rem}.saved-results h2{font-size:1.5rem}.saved-results>div>button,.saved-results li button,.search-result__meta button{padding:.35rem .55rem;color:var(--plum-700);background:transparent;border:1px solid var(--line);border-radius:.55rem;font-size:.75rem}.saved-results ul{display:grid;gap:.5rem;margin-top:1rem;list-style:none}.saved-results li{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:.7rem 0;border-top:1px solid var(--line)}.saved-results li a{font-weight:700}.local-note{margin-top:.7rem;font-size:.73rem}.search-results{margin-top:2rem;border-top:1px solid var(--line)}.search-results article{padding:1.4rem 0;border-bottom:1px solid var(--line)}.search-result__meta{display:flex;align-items:center;justify-content:space-between;gap:1rem}.search-results span{color:var(--gold-dark);font-size:.75rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase}.search-results h2{margin-top:.45rem;font-size:1.6rem}.search-results h2 a{text-decoration:none}.search-results p{margin-top:.4rem}.search-result__meta button[aria-pressed="true"]{color:var(--white);background:var(--plum-700);border-color:var(--plum-700)}
  @media(max-width:47.99rem){.site-search>div{grid-template-columns:1fr}.site-search .button{width:100%}}
</style>
