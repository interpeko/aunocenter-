---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import PageHero from '@/components/PageHero.astro';
import CallToAction from '@/components/CallToAction.astro';
import { resources, libraryMaterials } from '@/data/site';
const crumbs=[{label:'News & events'}];
const updates=[
  {type:'Institutional update',title:'AUNO Center institutional platform published',text:'The Center’s complete website, research-support portal, learning portfolio, policy framework, and public resource library are now available.',href:'/'},
  {type:'Program direction',title:'Future Development Program',text:'AUNO Center has published the interdisciplinary direction connecting human health, animal wellbeing, earth, nature, education, and responsible innovation.',href:'/future-development-program/'},
  {type:'Open learning',title:'Research learning materials available',text:`The resource library includes ${resources.length} practical guides and ${libraryMaterials.length} attributed presentation resources.`,href:'/resources/'}
];
---
<BaseLayout title="News and Events | AUNO Center" description="Verified AUNO Center institutional updates, resources, and confirmed events." breadcrumbs={crumbs}><Breadcrumbs items={crumbs}/><PageHero eyebrow="News & events" title="Verified updates, published with context." lead="This page distinguishes confirmed institutional updates from future events. Dates, speakers, partners, venues, and registration links appear only after verification."/>
<section class="section"><div class="shell"><div class="news-notice"><span>Event status</span><h2>No public event is currently open for registration.</h2><p>This is an intentional, accurate status—not a placeholder event schedule. Subscribe or follow AUNO Center for an announcement only after its date, time zone, format, accessibility information, and registration route are confirmed.</p></div></div></section>
<section class="section section--ivory"><div class="shell"><div class="section-heading"><p class="eyebrow">Verified institutional updates</p><h2>What is available now.</h2><p>These items describe published AUNO Center resources and programs; they do not imply unverified events, partnerships, or outcomes.</p></div><div class="update-grid mt-3">{updates.map((update,index)=><article><div><span>{update.type}</span><i>{String(index+1).padStart(2,'0')}</i></div><h3>{update.title}</h3><p>{update.text}</p><a class="text-link" href={update.href}>Explore <span class="icon icon--right" aria-hidden="true"></span></a></article>)}</div></div></section>
<section class="section"><div class="shell content-grid"><div><p class="eyebrow">Future announcements</p><h2>Every event record will be complete.</h2><p class="mt-1">When an event is approved, its record will state the responsible organiser, purpose, audience, exact date and time zone, delivery mode, participation requirements, accessibility route, privacy notice, fee if any, and registration status.</p></div><aside class="side-card"><h2>Looking for learning now?</h2><p>Browse ten self-contained course pathways or request a tailored institutional training program.</p><div class="button-row mt-1"><a class="button button--primary" href="/courses/">Browse courses</a><a class="button button--outline" href="/training/">Training</a></div></aside></div></section>
<CallToAction eyebrow="Verified announcements" title="Receive confirmed AUNO Center updates." text="Subscribe in the footer or follow the Center’s official channels. No schedule is represented as confirmed until it is published here." primaryLabel="Official channels" primaryHref="/contact/" secondaryLabel="Resource library" secondaryHref="/resources/"/></BaseLayout>
<style>.news-notice{max-width:64rem;padding:clamp(2rem,5vw,4rem);background:linear-gradient(120deg,var(--plum-950),#183e42);border-radius:var(--radius-lg);box-shadow:var(--shadow-lg)}.news-notice span,.update-grid span{color:var(--gold-light);font-size:.72rem;font-weight:800;letter-spacing:.14em;text-transform:uppercase}.news-notice h2{max-width:18ch;margin-top:2rem;color:white}.news-notice p{max-width:50rem;margin-top:1rem;color:rgba(255,255,255,.72)}.update-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}.update-grid article{display:flex;min-height:19rem;flex-direction:column;padding:1.5rem;background:white;border:1px solid var(--line);border-radius:var(--radius)}.update-grid article>div{display:flex;justify-content:space-between;gap:1rem}.update-grid span{color:var(--gold-dark)}.update-grid i{font-style:normal;color:var(--ink-soft);font-size:.72rem}.update-grid h3{margin-top:3rem}.update-grid p{margin-top:.8rem}.update-grid .text-link{margin-top:auto;padding-top:1rem}@media(max-width:61.99rem){.update-grid{grid-template-columns:1fr}}</style>
