---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import PageHero from '@/components/PageHero.astro';
import { academicModes, approvedSources, guidedResponses } from '../../shared/interpeko-knowledge.mjs';

const crumbs = [{ label: 'Interpeko academic research assistant' }];
const assistantData = JSON.stringify({ academicModes, approvedSources, guidedResponses }).replaceAll('<', '\\u003c');
---

<BaseLayout
  title="Interpeko Academic Research Assistant | AUNO Center"
  description="Use Interpeko for source-linked research navigation, question formulation, study-design thinking, analysis planning, evidence synthesis, writing, ethics, and AUNO Center guidance."
  breadcrumbs={crumbs}
>
  <Breadcrumbs items={crumbs} />
  <PageHero
    eyebrow="AI-assisted research navigation"
    title="Meet Interpeko."
    lead="An academic research-navigation and methods assistant that combines approved AUNO Center knowledge, transparent boundaries, source routes, and a privacy-aware guided fallback."
  >
    <div slot="actions" class="assistant-hero-actions">
      <a class="button button--gold" href="#ask-interpeko">Ask Interpeko</a>
      <a class="button button--ghost-light" href="/academic-standards/">Academic practice framework</a>
    </div>
  </PageHero>

  <section class="assistant-principle" aria-label="Interpeko principle">
    <div class="shell assistant-principle__inner">
      <strong>Structure thinking. Surface assumptions. Protect human accountability.</strong>
      <p>Interpeko supports research decisions; it does not make them for you.</p>
    </div>
  </section>

  <section class="section" id="ask-interpeko">
    <div class="shell assistant-layout">
      <div class="assistant-card">
        <div class="assistant-head">
          <span class="assistant-orb" aria-hidden="true">I</span>
          <div>
            <h2>Interpeko</h2>
            <p>Academic research-navigation and methods assistant</p>
          </div>
          <span class="status" id="assistant-status" role="status"><i aria-hidden="true"></i> Ready</span>
        </div>

        <div id="assistant-log" class="assistant-log" aria-live="polite" aria-busy="false">
          <div class="message message--assistant">
            <div class="message-meta"><strong>Interpeko</strong><span>Academic guide</span></div>
            <p>Hello. I can help you refine a research question, compare study-design options, structure an analysis plan, plan evidence synthesis, strengthen scientific writing, identify ethics considerations, or find the right AUNO Center route.</p>
            <p>I do not diagnose, approve research, invent citations, guarantee outcomes, or replace a supervisor, statistician, ethics committee, clinician, editor, lawyer, or institutional decision-maker.</p>
            <div class="source-links">
              <a href="/academic-standards/">Academic framework</a>
              <a href="/research-consultancy-disclaimer/">Assistant boundaries</a>
            </div>
          </div>
        </div>

        <form id="assistant-form" class="assistant-form">
          <label for="assistant-question">Describe the research decision or AUNO Center question</label>
          <textarea
            id="assistant-question"
            maxlength="1200"
            rows="3"
            placeholder="For example: Help me turn a broad diabetes topic into a focused research question."
            aria-describedby="assistant-privacy assistant-count"
            required
          ></textarea>
          <div class="assistant-form__footer">
            <p id="assistant-privacy"><strong>Privacy:</strong> never enter names, patient or participant details, confidential data, unpublished sensitive findings, credentials, or payment information.</p>
            <span id="assistant-count" aria-live="polite">0 / 1200</span>
            <button class="button button--primary" id="assistant-submit" type="submit">Ask Interpeko <span class="icon icon--up-right" aria-hidden="true"></span></button>
          </div>
        </form>

        <div class="prompt-panel">
          <div class="prompt-panel__head">
            <p>Suggested academic prompts</p>
            <button id="clear-assistant" type="button">Clear conversation</button>
          </div>
          <div class="prompt-row" aria-label="Suggested questions">
            <button type="button" data-prompt="Help me refine a broad topic into a researchable question.">Refine a research question</button>
            <button type="button" data-prompt="How should I compare possible study designs for my question?">Compare study designs</button>
            <button type="button" data-prompt="Give me an academic checklist for planning an analysis before seeing the results.">Plan an analysis</button>
            <button type="button" data-prompt="How should I structure a reproducible literature review?">Plan evidence synthesis</button>
            <button type="button" data-prompt="How can I improve the academic logic of a manuscript discussion?">Strengthen a manuscript</button>
            <button type="button" data-prompt="What should I consider when using AI responsibly in research?">Use AI responsibly</button>
          </div>
        </div>
      </div>

      <aside class="sticky-aside assistant-aside">
        <div class="side-card protocol-card">
          <p class="eyebrow">Response protocol</p>
          <h2>Academic guidance in four moves</h2>
          <ol>
            <li><span>01</span><div><strong>Clarify</strong><small>Question, context, intended inference and constraints</small></div></li>
            <li><span>02</span><div><strong>Appraise</strong><small>Options, assumptions, bias, ethics and feasibility</small></div></li>
            <li><span>03</span><div><strong>Structure</strong><small>Practical next steps and documentation</small></div></li>
            <li><span>04</span><div><strong>Verify</strong><small>Original sources and qualified human review</small></div></li>
          </ol>
        </div>
        <div class="side-card">
          <h2>AI and guided modes</h2>
          <p>Every response is identified as either <strong>AI-generated</strong> or <strong>Guided academic mode</strong>, so you always know which system produced the guidance.</p>
          <p>On the primary Netlify site, Interpeko can use a secure server-side OpenAI connection when configured. If AI mode is unavailable—or on the independent GitHub Pages mirror—it automatically uses the approved academic guide in your browser.</p>
          <a class="text-link" href="/privacy/">Read the AI privacy disclosure <span class="icon icon--right" aria-hidden="true"></span></a>
        </div>
        <div class="notice notice--critical">
          <h2>Human review required</h2>
          <p>Verify methods, calculations, claims, citations and decisions against original evidence and applicable institutional, ethics, professional and legal requirements.</p>
        </div>
      </aside>
    </div>
  </section>

  <section class="section section--ivory">
    <div class="shell">
      <div class="section-heading">
        <p class="eyebrow">Academic modes</p>
        <h2>Support for the decisions behind credible research.</h2>
        <p>Interpeko focuses on reasoning and navigation. Project-specific review still belongs in a defined human engagement.</p>
      </div>
      <div class="mode-grid">
        {academicModes.map((mode, index) => (
          <article>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{mode[0]}</h3>
            <p>{mode[1]}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell boundary-grid">
      <div>
        <p class="eyebrow">Responsible boundaries</p>
        <h2>What Interpeko will not do.</h2>
      </div>
      <ul class="check-list boundary-list">
        <li>Diagnose, treat, provide emergency guidance, or replace a healthcare professional</li>
        <li>Approve ethics, determine legal compliance, or replace institutional governance</li>
        <li>Fabricate data or citations, conceal assistance, plagiarise, or bypass academic rules</li>
        <li>Guarantee publication, funding, grades, approvals, employment, or preferred findings</li>
        <li>Receive identifiable, confidential, proprietary, unpublished, or otherwise sensitive data</li>
        <li>Make final statistical, authorship, editorial, hiring, or institutional decisions</li>
      </ul>
    </div>
  </section>
</BaseLayout>

<script id="interpeko-data" type="application/json" set:html={assistantData} is:inline></script>
<script>
  type Source = { id: string; label: string; href: string; summary: string; excerpt?: string; title?: string; type?: string; keywords?: string[] };
  type GuidedResponse = { id: string; title: string; answer: string; keywords: string[]; sourceIds: string[] };
  type ConversationMessage = { role: 'user' | 'assistant'; content: string };

  const dataNode = document.querySelector<HTMLScriptElement>('#interpeko-data');
  const data = dataNode ? JSON.parse(dataNode.textContent || '{}') as { approvedSources: Source[]; guidedResponses: GuidedResponse[] } : { approvedSources: [], guidedResponses: [] };
  const form = document.querySelector<HTMLFormElement>('#assistant-form');
  const input = document.querySelector<HTMLTextAreaElement>('#assistant-question');
  const log = document.querySelector<HTMLElement>('#assistant-log');
  const status = document.querySelector<HTMLElement>('#assistant-status');
  const submit = document.querySelector<HTMLButtonElement>('#assistant-submit');
  const counter = document.querySelector<HTMLElement>('#assistant-count');
  const clear = document.querySelector<HTMLButtonElement>('#clear-assistant');
  const initialLog = log?.innerHTML || '';
  const conversation: ConversationMessage[] = [];
  const onGitHubPages = location.hostname.endsWith('github.io');
  const repositoryBase = onGitHubPages ? '/aunocenter-' : '';
  const canUseAi = !onGitHubPages;

  function siteHref(href: string) {
    if (!href.startsWith('/')) return href;
    return `${repositoryBase}${href}`;
  }

  function getSessionId() {
    const key = 'interpeko-session';
    try {
      const saved = sessionStorage.getItem(key);
      if (saved) return saved;
      const created = globalThis.crypto?.randomUUID?.() || `session_${Date.now().toString(36)}_${Math.random().toString(36).slice(2, 12)}`;
      sessionStorage.setItem(key, created);
      return created;
    } catch {
      return `session_${Date.now().toString(36)}_${Math.random().toString(36).slice(2, 12)}`;
    }
  }

  const sessionId = getSessionId();

  function setStatus(label: string, active = false) {
    if (!status) return;
    status.classList.toggle('is-active', active);
    status.lastChild && (status.lastChild.textContent = ` ${label}`);
  }

  function findGuidedResponse(question: string) {
    const normalized = question.toLowerCase();
    let best: GuidedResponse | undefined;
    let bestScore = 0;
    for (const response of data.guidedResponses) {
      const score = response.keywords.reduce((total, keyword) => total + (normalized.includes(keyword) ? Math.max(1, keyword.split(' ').length) : 0), 0);
      if (score > bestScore) {
        best = response;
        bestScore = score;
      }
    }
    return best || {
      id: 'general',
      title: 'Research navigation',
      answer: 'Interpeko can help structure a research question, compare study designs, plan analysis, organise evidence synthesis, improve scientific writing, identify ethics considerations, or navigate AUNO Center services and courses.\n\nDescribe the research decision you are trying to make without including names, patient or participant details, confidential information, unpublished sensitive findings or protected data.',
      keywords: [],
      sourceIds: ['services', 'resources', 'academic-standards', 'request-support']
    };
  }

  function sourcesById(ids: string[]) {
    return ids.map(id => data.approvedSources.find(source => source.id === id)).filter(Boolean) as Source[];
  }

  function addUserMessage(text: string) {
    if (!log) return;
    const message = document.createElement('div');
    message.className = 'message message--user';
    const meta = document.createElement('div');
    meta.className = 'message-meta';
    const strong = document.createElement('strong');
    strong.textContent = 'You';
    meta.append(strong);
    const body = document.createElement('p');
    body.textContent = text;
    message.append(meta, body);
    log.append(message);
  }

  function addAssistantMessage(text: string, sources: Source[], mode: 'ai' | 'guided', notice?: string) {
    if (!log) return;
    const message = document.createElement('div');
    message.className = 'message message--assistant';
    const meta = document.createElement('div');
    meta.className = 'message-meta';
    const strong = document.createElement('strong');
    strong.textContent = 'Interpeko';
    const badge = document.createElement('span');
    badge.textContent = mode === 'ai' ? 'AI-generated' : 'Guided academic mode';
    meta.append(strong, badge);
    const body = document.createElement('p');
    body.className = 'message-answer';
    body.textContent = text;
    message.append(meta, body);
    if (notice) {
      const note = document.createElement('p');
      note.className = 'message-notice';
      note.textContent = notice;
      message.append(note);
    }
    if (sources.length) {
      const sourceLabel = document.createElement('small');
      sourceLabel.className = 'source-label';
      sourceLabel.textContent = 'Approved sources and next routes';
      const links = document.createElement('div');
      links.className = 'source-links';
      sources.slice(0, 4).forEach(source => {
        const anchor = document.createElement('a');
        anchor.textContent = source.label;
        anchor.href = siteHref(source.href);
        anchor.title = source.excerpt || source.summary;
        links.append(anchor);
      });
      const evidence = document.createElement('details');
      evidence.className = 'source-evidence';
      const evidenceSummary = document.createElement('summary');
      evidenceSummary.textContent = 'View approved source evidence';
      const evidenceList = document.createElement('ul');
      sources.slice(0, 4).forEach(source => {
        const item = document.createElement('li');
        const anchor = document.createElement('a');
        anchor.href = siteHref(source.href);
        anchor.textContent = source.title || source.label;
        const excerpt = document.createElement('p');
        excerpt.textContent = source.excerpt || source.summary;
        item.append(anchor, excerpt);
        evidenceList.append(item);
      });
      evidence.append(evidenceSummary, evidenceList);
      message.append(sourceLabel, links, evidence);
    }
    log.append(message);
    log.scrollTop = log.scrollHeight;
  }

  function addThinkingMessage() {
    if (!log) return null;
    const message = document.createElement('div');
    message.className = 'message message--assistant message--thinking';
    message.innerHTML = '<div class="message-meta"><strong>Interpeko</strong><span>Academic reasoning</span></div><p><i></i><i></i><i></i><span class="sr-only">Preparing a response</span></p>';
    log.append(message);
    log.scrollTop = log.scrollHeight;
    return message;
  }

  async function requestAi(question: string) {
    const controller = new AbortController();
    const timeout = window.setTimeout(() => controller.abort(), 18_000);
    try {
      const response = await fetch('/api/interpeko', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ question, sessionId, history: conversation.filter(message => message.role === 'user').slice(-4) }),
        signal: controller.signal
      });
      const payload = await response.json().catch(() => ({}));
      if (!response.ok || typeof payload.answer !== 'string') throw new Error(payload.error || 'AI mode unavailable');
      return { answer: payload.answer as string, sources: Array.isArray(payload.sources) ? payload.sources as Source[] : [], notice: payload.notice as string | undefined };
    } finally {
      window.clearTimeout(timeout);
    }
  }

  async function ask(question: string) {
    const value = question.trim();
    if (!value || !log || !submit) return;
    addUserMessage(value);
    const thinking = addThinkingMessage();
    submit.disabled = true;
    input && (input.disabled = true);
    log.setAttribute('aria-busy', 'true');
    setStatus(canUseAi ? 'Consulting academic model' : 'Using guided mode', true);

    try {
      if (canUseAi) {
        const result = await requestAi(value);
        thinking?.remove();
        addAssistantMessage(result.answer, result.sources, 'ai', result.notice);
        conversation.push({ role: 'user', content: value.slice(0, 600) }, { role: 'assistant', content: result.answer.slice(0, 600) });
        setStatus('AI answer ready');
        return;
      }
      throw new Error('guided');
    } catch {
      const guided = findGuidedResponse(value);
      thinking?.remove();
      addAssistantMessage(
        guided.answer,
        sourcesById(guided.sourceIds),
        'guided',
        onGitHubPages
          ? 'This response was generated from the approved on-device guide. Your question stayed in this browser.'
          : 'AI mode was unavailable, so Interpeko used the approved on-device academic guide. Verify before use.'
      );
      conversation.push({ role: 'user', content: value.slice(0, 600) }, { role: 'assistant', content: guided.answer.slice(0, 600) });
      setStatus('Guided answer ready');
    } finally {
      submit.disabled = false;
      input && (input.disabled = false);
      log.setAttribute('aria-busy', 'false');
      input?.focus();
    }
  }

  form?.addEventListener('submit', event => {
    event.preventDefault();
    const value = input?.value.trim() || '';
    if (!value) return;
    if (input) input.value = '';
    if (counter) counter.textContent = '0 / 1200';
    void ask(value);
  });

  input?.addEventListener('input', () => {
    if (counter) counter.textContent = `${input.value.length} / 1200`;
  });

  document.querySelectorAll<HTMLButtonElement>('[data-prompt]').forEach(button => button.addEventListener('click', () => {
    const prompt = button.dataset.prompt || button.textContent || '';
    if (input) input.value = prompt;
    if (counter) counter.textContent = `${prompt.length} / 1200`;
    void ask(prompt);
  }));

  clear?.addEventListener('click', () => {
    conversation.length = 0;
    if (log) log.innerHTML = initialLog;
    setStatus('Ready');
    input?.focus();
  });

  if (onGitHubPages) setStatus('Guided mode ready');
</script>

<style>
  .assistant-hero-actions{display:flex;flex-wrap:wrap;gap:.75rem;margin-top:1.7rem}
  .assistant-principle{color:white;background:#25112f}
  .assistant-principle__inner{display:flex;justify-content:space-between;gap:2rem;align-items:center;padding-block:1.15rem}
  .assistant-principle strong{font-family:var(--font-display);font-size:1.1rem;font-weight:500}.assistant-principle p{color:rgba(255,255,255,.72);font-size:.82rem}
  .assistant-layout{display:grid;grid-template-columns:minmax(0,1fr) minmax(18rem,.34fr);gap:2rem;align-items:start}
  .assistant-card{overflow:hidden;border:1px solid var(--line);border-radius:var(--radius-lg);box-shadow:var(--shadow-lg);background:white}
  .assistant-head{display:flex;gap:1rem;align-items:center;padding:1.15rem 1.3rem;color:white;background:#2b1435}
  .assistant-head h2{font-size:1.45rem}.assistant-head p{font-size:.76rem;color:rgba(255,255,255,.72)}
  .assistant-orb{display:grid;place-items:center;width:2.75rem;height:2.75rem;flex:0 0 auto;border:1px solid rgba(255,255,255,.3);border-radius:50%;background:var(--gold-light);font-family:var(--font-display);font-size:1.35rem;color:var(--plum-950)}
  .status{display:flex;gap:.45rem;align-items:center;margin-left:auto;padding:.35rem .55rem;border:1px solid rgba(255,255,255,.18);border-radius:2rem;background:rgba(255,255,255,.07);font-size:.75rem;white-space:nowrap}
  .status i{width:.5rem;height:.5rem;border-radius:50%;background:#8de5b0;box-shadow:0 0 0 .2rem rgba(141,229,176,.12)}.status.is-active i{background:var(--gold-light);animation:pulse 1.1s infinite}
  .assistant-log{display:grid;gap:1rem;min-height:23rem;max-height:38rem;overflow:auto;padding:1.35rem;background:#faf8fb}
  .message{max-width:89%;padding:1rem 1.1rem;border:1px solid var(--line);border-radius:.9rem;background:white;box-shadow:var(--shadow-sm)}
  .message--assistant{border-top-left-radius:.2rem}.message--user{justify-self:end;border-color:rgba(255,255,255,.08);border-top-right-radius:.2rem;background:var(--plum-900);color:white}
  .message--user p{color:rgba(255,255,255,.88)}.message-meta{display:flex;justify-content:space-between;gap:1rem;align-items:center}.message-meta strong{font-size:.78rem}.message-meta span{padding:.18rem .42rem;border-radius:2rem;background:var(--ivory);color:var(--plum-700);font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.05em}.message--user .message-meta span{background:rgba(255,255,255,.1);color:white}
  .message p{margin-top:.45rem}.message-answer{white-space:pre-wrap}.message-notice{padding-top:.7rem;border-top:1px solid var(--line);color:var(--ink-soft);font-size:.76rem}.source-label{display:block;margin-top:.8rem;color:var(--gold-dark);font-size:.73rem;font-weight:800;letter-spacing:.07em;text-transform:uppercase}
  .source-links{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:.45rem}.source-links a{padding:.34rem .54rem;border:1px solid var(--line);border-radius:2rem;background:#fff;color:var(--plum-700);font-size:.78rem;font-weight:780;text-decoration:none}.source-links a:hover{border-color:var(--gold)}
  .source-evidence{margin-top:.7rem;padding-top:.65rem;border-top:1px solid var(--line)}.source-evidence summary{color:var(--plum-700);font-size:.76rem;font-weight:750}.source-evidence ul{display:grid;gap:.65rem;margin-top:.7rem;padding:0;list-style:none}.source-evidence li{padding:.65rem;background:#faf8fb;border-radius:.6rem}.source-evidence li a{color:var(--plum-700);font-size:.8rem;font-weight:750}.source-evidence li p{margin-top:.2rem;font-size:.76rem;line-height:1.5}
  .message--thinking>p{display:flex;gap:.25rem}.message--thinking>p i{width:.45rem;height:.45rem;border-radius:50%;background:var(--gold);animation:thinking 1s infinite}.message--thinking>p i:nth-child(2){animation-delay:.16s}.message--thinking>p i:nth-child(3){animation-delay:.32s}
  .assistant-form{padding:1.25rem 1.35rem;border-top:1px solid var(--line)}.assistant-form>label{display:block;font-size:.86rem;font-weight:800}.assistant-form textarea{width:100%;min-height:6.2rem;margin-top:.45rem;padding:.8rem .9rem;resize:vertical;border:1px solid #cfc6d1;border-radius:.72rem;background:#fff;font:inherit}.assistant-form textarea:focus{outline:3px solid rgba(182,137,58,.16);border-color:var(--gold-dark)}
  .assistant-form__footer{display:grid;grid-template-columns:minmax(0,1fr) auto auto;gap:.75rem;align-items:center;margin-top:.65rem}.assistant-form__footer p{font-size:.75rem}.assistant-form__footer>span{color:var(--ink-soft);font-size:.75rem;white-space:nowrap}.assistant-form__footer .button{white-space:nowrap}
  .prompt-panel{padding:1rem 1.35rem 1.3rem;border-top:1px solid var(--line);background:#fcfbf8}.prompt-panel__head{display:flex;justify-content:space-between;gap:1rem;align-items:center}.prompt-panel__head p{font-size:.75rem;font-weight:800;text-transform:uppercase;letter-spacing:.08em}.prompt-panel__head button{border:0;background:none;color:var(--plum-700);font-size:.75rem;text-decoration:underline;cursor:pointer}.prompt-row{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:.75rem}.prompt-row button{padding:.5rem .7rem;border:1px solid var(--line);border-radius:2rem;background:white;color:var(--ink);font-size:.78rem;cursor:pointer}.prompt-row button:hover{border-color:var(--gold);color:var(--plum-700)}
  .assistant-aside{display:grid;gap:1rem}.protocol-card .eyebrow{margin-bottom:.7rem}.protocol-card ol{display:grid;gap:.8rem;margin-top:1rem;list-style:none}.protocol-card li{display:grid;grid-template-columns:2rem 1fr;gap:.65rem;align-items:start}.protocol-card li>span{display:grid;place-items:center;width:1.8rem;height:1.8rem;border:1px solid var(--gold);border-radius:50%;color:var(--gold-dark);font-size:.72rem;font-weight:800}.protocol-card li div{display:grid}.protocol-card li strong{font-family:var(--font-display);font-size:1.02rem;font-weight:500}.protocol-card li small{color:var(--ink-soft);line-height:1.45}
  .mode-grid{display:grid;grid-template-columns:repeat(3,1fr);border-top:1px solid var(--line);border-left:1px solid var(--line)}.mode-grid article{min-height:15rem;padding:1.5rem;border-right:1px solid var(--line);border-bottom:1px solid var(--line);background:white}.mode-grid span{color:var(--gold-dark);font-size:.74rem;font-weight:800}.mode-grid h3{margin-top:3rem;font-size:1.45rem}.mode-grid p{margin-top:.7rem;font-size:.85rem}
  .boundary-grid{display:grid;grid-template-columns:.7fr 1fr;gap:clamp(3rem,8vw,8rem);align-items:start}.boundary-grid h2{max-width:13ch}.boundary-list{margin-top:0}
  @keyframes thinking{0%,70%,100%{opacity:.25;transform:translateY(0)}35%{opacity:1;transform:translateY(-.15rem)}}@keyframes pulse{50%{opacity:.45}}
