---
import BaseLayout from '@/layouts/BaseLayout.astro';import Breadcrumbs from '@/components/Breadcrumbs.astro';import PageHero from '@/components/PageHero.astro';const crumbs=[{label:'Interpeko research assistant'}];
---
<BaseLayout title="Interpeko Research Assistant | AUNO Center" description="A privacy-aware, source-linked guide to AUNO Center services, courses, resources, PubMed search, and contact routes." breadcrumbs={crumbs}><Breadcrumbs items={crumbs}/><PageHero eyebrow="AI-guided institutional assistant" title="Meet Interpeko." lead="Interpeko helps you navigate AUNO Center’s approved public information. It identifies its limits, links to source pages, and routes complex questions to a human."/><section class="section"><div class="shell assistant-layout"><div class="assistant-card"><div class="assistant-head"><span class="assistant-orb" aria-hidden="true">I</span><div><h2>Interpeko</h2><p>AI-guided website assistant · public information only</p></div><span class="status">Ready</span></div><div id="assistant-log" class="assistant-log" aria-live="polite"><div class="message message--assistant"><strong>Interpeko</strong><p>Hello. I’m an automated AUNO Center research assistant. I can guide you to services, courses, learning resources, PubMed, applications, and contact routes. I cannot diagnose, guarantee research outcomes, make hiring decisions, or replace professional advice.</p><div class="source-links"><a href="/about/">About AUNO Center</a><a href="/research-consultancy-disclaimer/">My limits</a></div></div></div><form id="assistant-form" class="assistant-form"><label for="assistant-question">Ask about AUNO Center</label><div><input id="assistant-question" maxlength="300" placeholder="For example: Which course covers questionnaire design?" required/><button class="button button--primary" type="submit">Ask</button></div><p>Do not enter names, patient details, confidential data, unpublished findings, credentials, or other sensitive information.</p></form><div class="prompt-row" aria-label="Suggested questions"><button type="button">I need research support</button><button type="button">Show me courses</button><button type="button">Find research articles</button><button type="button">How can I join?</button></div></div><aside class="sticky-aside"><div class="side-card"><h2>How Interpeko works</h2><p>It uses a small approved knowledge map built into this page. It does not search private submissions, make clinical recommendations, or send your question to an external AI service.</p></div><div class="side-card"><h2>Need a person?</h2><p>For project-specific, privacy, accessibility, or institutional questions, use the relevant secure form or email AUNO Center.</p><a class="text-link" href="/contact/">Contact routes →</a></div></aside></div></section></BaseLayout>
<script>
const routes=[
 {keys:['service','support','method','statistic','questionnaire','manuscript','proposal','analysis'],text:'AUNO Center provides structured support across research design, statistics, questionnaires, interpretation, writing, proposals, manuscripts, and evidence review. Project-specific scope is confirmed after an initial review.',links:[['Research services','/services/'],['Request support','/request-support/']]},
 {keys:['course','learn','training','scholarship','enroll'],text:'The learning portfolio includes ten courses in research foundations, proposals, biostatistics, questionnaires, literature review, writing, systematic reviews, appraisal, ethics, and responsible AI. Enrollment and scholarships use separate application routes.',links:[['Browse courses','/courses/'],['Training','/training/']]},
 {keys:['pubmed','article','literature','paper','evidence'],text:'You can search public biomedical literature through AUNO Center’s interface to the official NCBI PubMed service, or browse the Center’s attributed learning materials and practical guides.',links:[['PubMed search','/pubmed-search/'],['Resource library','/resources/']]},
 {keys:['join','job','volunteer','collaborat','work','career'],text:'The professional interest portal accepts research, education, consulting, student, institutional, and community interests. Submission does not guarantee a role, appointment, payment, or selection.',links:[['Join AUNO Center','/join/'],['International collaboration','/international-collaboration/']]},
 {keys:['founder','director','mustafa','about','mission','vision'],text:'AUNO Center was founded and is directed by Mustafa Saadabi of the Faculty of Medicine. Its vision connects human health, animal wellbeing, earth, nature, education, and responsible innovation through research.',links:[['Founder and Center profile','/about/#founder'],['Vision and mission','/about/vision-mission/']]},
 {keys:['contact','email','phone','social','youtube','whatsapp'],text:'Use the official contact page for email, phone, social channels, media enquiries, and the appropriate institutional form.',links:[['Contact AUNO Center','/contact/'],['Media and YouTube','/media/']]}
];
const form=document.querySelector('#assistant-form');const input=document.querySelector('#assistant-question');const log=document.querySelector('#assistant-log');
function answer(question){const q=question.toLowerCase();const match=routes.find(route=>route.keys.some(key=>q.includes(key)))||{text:'I do not have an approved answer for that question. I can guide you through public AUNO Center pages, or you can send a non-confidential message to the Center.',links:[['Frequently asked questions','/faq/'],['Contact AUNO Center','/contact/']]};const user=document.createElement('div');user.className='message message--user';user.innerHTML='<strong>You</strong><p></p>';user.querySelector('p').textContent=question;const reply=document.createElement('div');reply.className='message message--assistant';const strong=document.createElement('strong');strong.textContent='Interpeko';const p=document.createElement('p');p.textContent=match.text;const links=document.createElement('div');links.className='source-links';match.links.forEach(([label,href])=>{const a=document.createElement('a');a.textContent=label;a.href=href;links.append(a)});reply.append(strong,p,links);log.append(user,reply);log.scrollTop=log.scrollHeight}
form?.addEventListener('submit',event=>{event.preventDefault();const value=input?.value.trim();if(value){answer(value);input.value=''}});document.querySelectorAll('.prompt-row button').forEach(button=>button.addEventListener('click',()=>answer(button.textContent||'')));
</script>
<style>.assistant-layout{display:grid;grid-template-columns:minmax(0,1fr) minmax(17rem,.32fr);gap:2rem;align-items:start}.assistant-card{overflow:hidden;border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);background:white}.assistant-head{display:flex;gap:1rem;align-items:center;padding:1rem 1.2rem;color:white;background:var(--plum-900)}.assistant-head h2{font-size:1.3rem}.assistant-head p{font-size:.75rem;color:rgba(255,255,255,.7)}.assistant-orb{display:grid;place-items:center;width:2.5rem;height:2.5rem;border-radius:50%;background:var(--gold);font-family:var(--font-display);color:var(--plum-900)}.status{margin-left:auto;font-size:.7rem}.assistant-log{display:grid;gap:1rem;max-height:31rem;overflow:auto;padding:1.2rem;background:var(--ivory)}.message{max-width:86%;padding:1rem 1.1rem;border:1px solid var(--line);border-radius:.8rem;background:white}.message--user{justify-self:end;background:var(--plum-900);color:white}.message--user p{color:rgba(255,255,255,.85)}.message strong{font-size:.75rem}.message p{margin-top:.35rem}.source-links{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:.8rem}.source-links a{font-size:.75rem;font-weight:750;color:var(--plum-700)}.assistant-form{padding:1.2rem}.assistant-form label{font-size:.8rem;font-weight:800}.assistant-form>div{display:grid;grid-template-columns:1fr auto;gap:.5rem;margin-top:.4rem}.assistant-form input{min-height:3rem;padding:.7rem;border:1px solid var(--line)}.assistant-form>p{margin-top:.5rem;font-size:.7rem}.prompt-row{display:flex;flex-wrap:wrap;gap:.5rem;padding:0 1.2rem 1.2rem}.prompt-row button{padding:.45rem .65rem;border:1px solid var(--line);border-radius:2rem;background:white;font-size:.72rem;cursor:pointer}@media(max-width:61.99rem){.assistant-layout{grid-template-columns:1fr}}@media(max-width:35rem){.assistant-form>div{grid-template-columns:1fr}.message{max-width:95%}}</style>
