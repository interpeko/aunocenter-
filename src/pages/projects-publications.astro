---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import PageHero from '@/components/PageHero.astro';

const crumbs = [{ label: 'Projects & publications' }];
const recordFields = [
  ['Status', 'Proposal, active project, completed work, preprint, publication, educational output, or institutional contribution.'],
  ['Responsibility', 'Verified contributors, affiliations, contributor roles, and AUNO Center’s specific contribution.'],
  ['Provenance', 'Relevant dates, version, funding, conflicts, acknowledgements, and supporting public record.'],
  ['Governance', 'Ethics review, registration, protocol, data-access, permission, or other applicable context.'],
  ['Identifier', 'DOI, PMID, registry number, repository record, persistent URL, or another verifiable identifier.'],
  ['Limitations', 'Scope, uncertainty, departures, correction history, and boundaries on use or interpretation.']
];
---

<BaseLayout title="Projects and Publications | AUNO Center" description="Verified AUNO Center projects, outputs, publications, and research contribution records." breadcrumbs={crumbs}>
  <Breadcrumbs items={crumbs} />
  <PageHero eyebrow="Research record" title="Projects and publications, documented responsibly." lead="This register is reserved for work whose status, authorship, contribution, dates, identifiers, governance context, and public links have been verified." />

  <section class="section">
    <div class="shell content-grid">
      <div>
        <p class="eyebrow">Register status</p>
        <h2>No verified public entries are currently listed.</h2>
        <p class="mt-1 max-copy">AUNO Center will not imply completed research, partnerships, publications, or impact before supporting records are available. This transparent status will change only when an evidence-backed record can be published responsibly.</p>
        <div class="register-status mt-3">
          <div><span aria-hidden="true">✓</span><div><strong>Register active</strong><small>Verification criteria published</small></div></div>
          <dl><dt>Public entries</dt><dd>None currently verified</dd><dt>Last register review</dt><dd>12 July 2026</dd><dt>Record policy</dt><dd><a href="/editorial-policy/">Editorial & Corrections Policy</a></dd></dl>
        </div>
      </div>
      <aside class="sticky-aside">
        <div class="side-card"><h2>Why an empty register matters</h2><p>A sober empty state is more credible than an unsupported portfolio. It separates institutional ambition from completed, attributable, and publicly verifiable work.</p></div>
        <div class="notice"><h2>Submit a correction</h2><p>If a verified AUNO Center record is missing or described incorrectly, send the public evidence and record details to the official contact address.</p><a class="text-link" href="/contact/">Contact AUNO Center →</a></div>
      </aside>
    </div>
  </section>

  <section class="section section--ivory">
    <div class="shell">
      <div class="section-heading"><p class="eyebrow">Publication record criteria</p><h2>Every future entry should be auditable.</h2><p>Fields are included when applicable and supported; absence or non-applicability should be stated rather than silently obscured.</p></div>
      <div class="record-grid">{recordFields.map((field, index) => <article><span>{String(index + 1).padStart(2, '0')}</span><h3>{field[0]}</h3><p>{field[1]}</p></article>)}</div>
    </div>
  </section>

  <section class="section">
    <div class="shell content-grid">
      <div><p class="eyebrow">Educational scholarship</p><h2>Research resources are published separately.</h2><p class="max-copy mt-1">AUNO Center’s educational guides and contributor-supplied learning materials are not presented as peer-reviewed research publications. Their publication or attribution status is shown in the Resource Library.</p><div class="button-row mt-2"><a class="button button--primary" href="/resources/">Open Resource Library</a><a class="button button--outline" href="/academic-standards/">Academic framework</a></div></div>
      <div><p class="eyebrow">Discover external evidence</p><h2>Search official PubMed records.</h2><p class="max-copy mt-1">Use AUNO Center’s privacy-aware interface to search public biomedical literature from the U.S. National Library of Medicine.</p><a class="button button--outline mt-2" href="/pubmed-search/">Open PubMed search</a></div>
    </div>
  </section>
</BaseLayout>

<style>
  .register-status{padding:1.4rem;border:1px solid var(--line);border-left:4px solid var(--gold);background:var(--ivory)}.register-status>div{display:flex;gap:.8rem;align-items:center}.register-status>div>span{display:grid;place-items:center;width:2.2rem;height:2.2rem;border-radius:50%;background:var(--plum-900);color:white}.register-status>div div{display:grid}.register-status strong{font-family:var(--font-display);font-size:1.25rem;font-weight:500}.register-status small{color:var(--ink-soft)}.register-status dl{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-top:1.3rem;padding-top:1rem;border-top:1px solid var(--line)}.register-status dt{color:var(--gold-dark);font-size:.62rem;font-weight:800;letter-spacing:.07em;text-transform:uppercase}.register-status dd{margin-top:.2rem;font-size:.78rem}
  .record-grid{display:grid;grid-template-columns:repeat(3,1fr);border-top:1px solid var(--line);border-left:1px solid var(--line)}.record-grid article{min-height:15rem;padding:1.4rem;border-right:1px solid var(--line);border-bottom:1px solid var(--line);background:white}.record-grid span{color:var(--gold-dark);font-size:.65rem;font-weight:800}.record-grid h3{margin-top:2.8rem;font-size:1.4rem}.record-grid p{margin-top:.7rem;font-size:.84rem}
  @media(max-width:61.99rem){.record-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:47.99rem){.register-status dl,.record-grid{grid-template-columns:1fr}.record-grid article{min-height:auto}.record-grid h3{margin-top:2rem}}
</style>
