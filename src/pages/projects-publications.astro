---
import BaseLayout from '@/layouts/BaseLayout.astro';import Breadcrumbs from '@/components/Breadcrumbs.astro';import PageHero from '@/components/PageHero.astro';const crumbs=[{label:'Projects & publications'}];
---
<BaseLayout title="Projects and Publications | AUNO Center" description="Verified AUNO Center projects, outputs, publications, and research contribution records." breadcrumbs={crumbs}><Breadcrumbs items={crumbs}/><PageHero eyebrow="Research record" title="Projects and publications, documented responsibly." lead="This register is reserved for work whose status, authorship, contribution, dates, identifiers, and public links have been verified."/><section class="section"><div class="shell content-grid"><div><p class="eyebrow">Verified register</p><h2>No public entries are listed yet.</h2><p class="mt-1 max-copy">AUNO Center will not imply completed research, partnerships, publications, or impact before supporting records are available. Future entries will distinguish proposals, active projects, completed work, preprints, peer-reviewed publications, educational materials, and institutional contributions.</p><div class="empty-registry mt-3"><span>0</span><div><h3>Verified public records</h3><p>This transparent empty state is intentional. It will be replaced only by evidence-backed records.</p></div></div></div><aside class="sticky-aside"><div class="side-card"><h2>Each record will show</h2><ul class="check-list"><li>Accurate title and status</li><li>Responsible people and affiliations</li><li>AUNO Center’s specific contribution</li><li>Dates and verified partners</li><li>Ethics or registration context where relevant</li><li>DOI, PubMed, registry, or repository link</li><li>Conflicts, funding, and limitations</li></ul></div></aside></div></section><section class="section section--ivory"><div class="shell"><div class="section-heading"><p class="eyebrow">Discover evidence</p><h2>Search the official PubMed service.</h2><p>Use AUNO Center’s privacy-aware interface to search public biomedical literature from the National Library of Medicine.</p><a class="button button--primary mt-2" href="/pubmed-search/">Open PubMed search</a></div></div></section></BaseLayout><style>.empty-registry{display:grid;grid-template-columns:auto 1fr;gap:1.5rem;align-items:center;padding:2rem;border:1px solid var(--line);background:var(--ivory);border-radius:var(--radius)}.empty-registry>span{font-family:var(--font-display);font-size:4rem;color:var(--plum-700)}.empty-registry h3{font-size:1.35rem}</style>
