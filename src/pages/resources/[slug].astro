---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CallToAction from '@/components/CallToAction.astro';
import { resources, services, SITE, type Resource } from '@/data/site';

export function getStaticPaths() { return resources.map(resource => ({ params: { slug: resource.slug }, props: { resource } })); }
interface Props { resource: Resource }
const { resource } = Astro.props;
const relatedService = services.find(service => service.slug === resource.relatedService);
const related = resources.filter(item => item.slug !== resource.slug && (item.category === resource.category || item.relatedService === resource.relatedService)).slice(0, 3);
const crumbs = [{ label: 'Research resources', href: '/resources/' }, { label: resource.title }];
const canonical = new URL(`/resources/${resource.slug}/`, Astro.site ?? Astro.url.origin).href;
const published = '2026-07-12';
const version = '1.0';
const articleSchema = {
  '@context': 'https://schema.org', '@type': 'Article', headline: resource.title, description: resource.summary,
  mainEntityOfPage: canonical, datePublished: published, dateModified: published, isAccessibleForFree: true,
  author: { '@type': 'Organization', name: SITE.name }, publisher: { '@type': 'Organization', name: SITE.name }
};
const slugify = (text: string) => text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
---

<BaseLayout title={`${resource.title} | AUNO Center`} description={resource.summary} breadcrumbs={crumbs} type="article" schema={articleSchema}>
  <header class="article-header"><div class="shell article-header__inner"><p class="eyebrow">{resource.category}</p><h1>{resource.title}</h1><p class="article-header__summary">{resource.summary}</p><div class="article-meta"><span>{resource.readingTime}</span><span>Educational research resource</span><span>Not externally peer reviewed</span></div></div></header>
  <section class="section"><div class="shell article-layout">
    <aside><nav class="article-toc" aria-label="On this page"><p>On this page</p><ol>{resource.sections.map(section => <li><a href={`#${slugify(section.heading)}`}>{section.heading}</a></li>)}</ol></nav></aside>
    <article class="article-body"><p>{resource.intro}</p>
      <div class="publication-record" aria-label="Publication record">
        <dl><div><dt>Responsible organisation</dt><dd>AUNO Center</dd></div><div><dt>Version</dt><dd>{version}</dd></div><div><dt>Published</dt><dd>12 July 2026</dd></div><div><dt>Review status</dt><dd>Editorial educational content; not externally peer reviewed</dd></div></dl>
        <p><strong>Suggested citation:</strong> AUNO Center. “{resource.title}.” Version {version}, 2026. <a href={canonical}>{canonical}</a>.</p>
        <p><a href="/editorial-policy/">Editorial, attribution, versioning, and corrections policy <span class="icon icon--right" aria-hidden="true"></span></a></p>
      </div>
      {resource.sections.map(section => <section id={slugify(section.heading)}><h2>{section.heading}</h2>{section.paragraphs.map(paragraph => <p>{paragraph}</p>)}{section.points && <ul>{section.points.map(point => <li>{point}</li>)}</ul>}</section>)}
      <div class="article-takeaway"><h2>Key takeaway</h2><p>{resource.takeaway}</p></div>
      <div class="notice mt-3"><h2>Use this resource responsibly</h2><p>This guide is educational and general. Apply it in accordance with your discipline, institution, ethics approvals, law, professional standards, and project context.</p></div>
    </article>
  </div></section>
  <section class="section section--ivory"><div class="shell"><div class="content-grid"><div><p class="eyebrow">Related support</p><h2>{relatedService?.title ?? 'Research support'}</h2><p class="max-copy mt-1">{relatedService?.summary}</p><a class="button button--outline mt-2" href={`/services/${relatedService?.slug}/`}>Explore this service</a></div><div><p class="eyebrow">Continue reading</p><ul class="related-resources">{related.map(item => <li><a href={`/resources/${item.slug}/`}><small>{item.category}</small><strong>{item.title}</strong><span class="icon icon--up-right" aria-hidden="true"></span></a></li>)}</ul></div></div></div></section>
  <CallToAction title="Apply strong principles to a real research decision." text="Describe the project context and the methodological question that would benefit from focused support." />
</BaseLayout>

<style>
  .publication-record{margin-top:2rem;padding:1.2rem;border:1px solid var(--line);border-left:3px solid var(--gold);background:var(--ivory)}.publication-record dl{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:.9rem}.publication-record dt{color:var(--gold-dark);font-size:.62rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase}.publication-record dd{margin-top:.2rem;font-size:.78rem}.publication-record p{margin-top:1rem;font-size:.76rem;overflow-wrap:anywhere}
  .related-resources{list-style:none;border-top:1px solid var(--line)}.related-resources li{border-bottom:1px solid var(--line)}.related-resources a{display:grid;grid-template-columns:1fr 2rem;gap:.6rem;padding:1rem 0;text-decoration:none}.related-resources small{grid-column:1;color:var(--gold-dark);font-size:.68rem;font-weight:800;text-transform:uppercase}.related-resources strong{grid-column:1;font-family:var(--font-display);font-size:1.1rem;font-weight:500;line-height:1.3}.related-resources span{grid-column:2;grid-row:1/3;align-self:center}
  @media(max-width:47.99rem){.publication-record dl{grid-template-columns:1fr}}
</style>
