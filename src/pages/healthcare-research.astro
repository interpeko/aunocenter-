---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import PageHero from '@/components/PageHero.astro';
import CallToAction from '@/components/CallToAction.astro';
const crumbs=[{label:'Healthcare research'}];
const support=[['Questions & protocols','Clarify clinical, health-services, public-health, or workforce questions and align them with an ethical, feasible design.'],['Measurement & instruments','Plan outcomes, variables, patient- or professional-facing questionnaires, and appropriate testing.'],['Statistics & interpretation','Develop analysis plans, review data readiness, examine assumptions, and interpret uncertainty in context.'],['Evidence synthesis','Create transparent review protocols, search approaches, screening, appraisal, and synthesis workflows.'],['Reporting & manuscripts','Strengthen methodological reporting, tables, figures, limitations, and evidence-aligned conclusions.'],['Team capability','Build research-methods confidence through workshops, clinics, and tailored learning programmes.']];
---

<BaseLayout title="Healthcare Research Support | AUNO Center" description="Methodological, statistical, questionnaire, evidence-review, reporting, and training support for responsible healthcare research." breadcrumbs={crumbs}>
  <Breadcrumbs items={crumbs}/><PageHero eyebrow="Healthcare research" title="Better methods for meaningful healthcare evidence." lead="Healthcare research requires methodological rigor alongside careful attention to patients, professionals, systems, privacy, and the practical meaning of findings.">
    <div slot="actions" class="button-row"><a class="button button--gold" href="/request-support/?service=healthcare-research">Discuss a healthcare research project <span aria-hidden="true">↗</span></a></div>
  </PageHero>

  <section class="section"><div class="shell"><div class="health-intro"><div><p class="eyebrow">Purposeful evidence</p><h2>Research decisions carry real-world responsibilities.</h2></div><div><p>Healthcare questions may involve patients, professionals, services, organisations, communities, sensitive data, and decisions with practical consequences. Sound support must keep method, privacy, ethics, and interpretation connected.</p><p>AUNO Center works on the research process—not clinical care. All activities remain subject to the authorised institutional, ethics, privacy, legal, professional, and regulatory pathways for the setting.</p></div></div></div></section>

  <section class="section section--ivory"><div class="shell"><div class="section-heading"><p class="eyebrow">Support areas</p><h2>Across the healthcare research journey.</h2></div><div class="health-grid">{support.map(([title,text],index)=><article><span>{String(index+1).padStart(2,'0')}</span><h3>{title}</h3><p>{text}</p></article>)}</div></div></section>

  <section class="section"><div class="shell content-grid"><article class="prose"><p class="eyebrow">Safety & responsibility</p><h2 class="mt-0">Protect people, data, and the meaning of the evidence.</h2><ul class="check-list"><li>Do not submit identifiable patient or participant information through website forms.</li><li>Obtain every required clinical, institutional, ethics, privacy, and data-governance approval.</li><li>Use the appropriate authority to determine whether activity is research, quality improvement, audit, evaluation, or another regulated category.</li><li>Collect the minimum information needed and use approved systems for access, transfer, storage, sharing, and retention.</li><li>Keep conclusions within the study design, data quality, assumptions, uncertainty, and subject-matter context.</li><li>Do not use consultancy output as a substitute for clinical judgement or emergency care.</li></ul><h3>Patient and public perspective</h3><p>Where relevant, healthcare research should consider how patients, carers, professionals, and communities understand the problem, burden, outcomes, communication, and value of the work. Applicable involvement and consent arrangements must be planned through the authorised process.</p></article><aside class="sticky-aside"><div class="notice notice--critical"><h2>Not medical care</h2><p>AUNO Center does not provide diagnosis, treatment recommendations, medical advice, prescriptions, emergency services, or patient-specific guidance.</p></div><div class="side-card"><h2>Research consultancy only</h2><p>Healthcare research support is not medical, legal, regulatory, privacy, or ethics advice and does not constitute approval.</p><a href="/research-consultancy-disclaimer/">Read the full disclaimer →</a></div></aside></div></section>

  <section class="section section--plum"><div class="shell healthcare-path"><div><p class="eyebrow eyebrow--light">A responsible pathway</p><h2>Question → protocol → approval → evidence → interpretation.</h2></div><ol><li><span>01</span><strong>Define the health question and intended use.</strong></li><li><span>02</span><strong>Plan methods, people, data, and safeguards.</strong></li><li><span>03</span><strong>Secure the required institutional approvals.</strong></li><li><span>04</span><strong>Collect and analyse through approved systems.</strong></li><li><span>05</span><strong>Report uncertainty, limitations, and meaning responsibly.</strong></li></ol></div></section>
  <CallToAction title="Strengthen the methods behind healthcare evidence." text="Share a non-confidential overview of the question, project stage, approvals, and support required." />
</BaseLayout>

<style>
  .health-intro{display:grid;grid-template-columns:1fr .8fr;gap:clamp(3rem,8vw,8rem)}.health-intro h2{max-width:14ch}.health-intro div:last-child p+p{margin-top:1rem}
  .health-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}.health-grid article{min-height:17rem;padding:1.5rem;background:white;border:1px solid var(--line);border-radius:var(--radius)}.health-grid span{color:var(--gold-dark);font-size:.7rem;font-weight:800}.health-grid h3{margin-top:3rem}.health-grid p{margin-top:.7rem}
  .healthcare-path{display:grid;grid-template-columns:.8fr 1fr;gap:clamp(3rem,8vw,8rem);align-items:start}.healthcare-path h2{max-width:14ch;color:white}.healthcare-path ol{list-style:none;border-top:1px solid rgba(255,255,255,.2)}.healthcare-path li{display:grid;grid-template-columns:3rem 1fr;gap:1rem;padding:1rem 0;border-bottom:1px solid rgba(255,255,255,.2)}.healthcare-path li span{color:var(--gold-light);font-size:.7rem;font-weight:800}.healthcare-path li strong{color:white;font-weight:600}
  @media(max-width:61.99rem){.health-grid{grid-template-columns:repeat(2,1fr)}.healthcare-path{grid-template-columns:1fr}}
  @media(max-width:47.99rem){.health-intro,.health-grid{grid-template-columns:1fr}}
</style>
