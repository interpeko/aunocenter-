---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | AUNO Center" description="The requested AUNO Center page could not be found." noindex>
  <section class="not-found"><div class="not-found__orbit" aria-hidden="true"><span>404</span><i></i><i></i></div><div class="shell not-found__copy"><p class="eyebrow eyebrow--light">Page not found</p><h1>Even careful searches sometimes return no result.</h1><p>The address may have changed, the page may have moved, or the link may be incomplete. Let’s refine the path.</p><div class="button-row"><a class="button button--gold" href="/">Return home</a><a class="button button--ghost-light" href="/services/">Explore research services</a><a class="button button--ghost-light" href="/contact/">Contact AUNO Center</a></div></div></section>
</BaseLayout>

<style>.not-found{position:relative;min-height:70vh;display:grid;align-items:center;overflow:hidden;color:white;background:linear-gradient(125deg,var(--plum-950),#361641 65%,#173d42)}.not-found__copy{position:relative;z-index:2;padding-block:7rem}.not-found h1{max-width:13ch}.not-found__copy>p:not(.eyebrow){max-width:42rem;margin-top:1.3rem;color:rgba(255,255,255,.74);font-size:1.1rem}.not-found__orbit{position:absolute;right:-4rem;top:50%;width:34rem;height:34rem;display:grid;place-items:center;border:1px solid rgba(255,255,255,.2);border-radius:50%;transform:translateY(-50%)}.not-found__orbit::before,.not-found__orbit::after,.not-found__orbit i{content:'';position:absolute;inset:0;border:1px solid rgba(194,154,82,.35);border-radius:50%}.not-found__orbit::before{transform:scaleX(.4)}.not-found__orbit::after{transform:scaleY(.4)}.not-found__orbit i:first-of-type{transform:rotate(40deg) scaleX(.6)}.not-found__orbit i:last-of-type{transform:rotate(-40deg) scaleX(.6)}.not-found__orbit span{color:rgba(255,255,255,.1);font-family:var(--font-display);font-size:10rem}@media(max-width:47.99rem){.not-found__orbit{right:-16rem;opacity:.6}}</style>
