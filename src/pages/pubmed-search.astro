---
import BaseLayout from '@/layouts/BaseLayout.astro';import Breadcrumbs from '@/components/Breadcrumbs.astro';import PageHero from '@/components/PageHero.astro';const crumbs=[{label:'PubMed search'}];
---
<BaseLayout title="Search PubMed | AUNO Center" description="Search public biomedical literature through the official NCBI PubMed E-utilities service." breadcrumbs={crumbs}><Breadcrumbs items={crumbs}/><PageHero eyebrow="Biomedical literature" title="Search the official PubMed database." lead="A focused interface to public biomedical records supplied by the U.S. National Library of Medicine. AUNO Center does not alter, rank, or endorse the scientific conclusions in those records." tone="gold"/><section class="section"><div class="shell pubmed-layout"><main><form id="pubmed-form" class="search-panel"><label for="pubmed-query">Keywords, topic, author, or PubMed query</label><div><input id="pubmed-query" name="q" type="search" minlength="2" maxlength="300" placeholder="e.g. questionnaire validity healthcare" required/><button class="button button--primary" type="submit">Search PubMed</button></div><p>Queries are sent to NCBI only when you submit. Do not enter private, patient, participant, or confidential information.</p></form><div id="pubmed-status" class="pubmed-status" role="status" aria-live="polite">Enter a public literature topic to begin.</div><div id="pubmed-results" class="pubmed-results"></div></main><aside class="sticky-aside"><div class="side-card"><h2>Official source</h2><p>Results come from NCBI E-utilities and link to records on pubmed.ncbi.nlm.nih.gov.</p><a class="text-link" href="https://pubmed.ncbi.nlm.nih.gov/" target="_blank" rel="noopener">Open PubMed directly ↗</a></div><div class="notice"><h2>Evidence notice</h2><p>A database result is not a quality judgement or medical recommendation. Appraise methods, relevance, reporting, uncertainty, corrections, and the complete evidence base.</p></div></aside></div></section></BaseLayout>
<script>
const form=document.querySelector<HTMLFormElement>('#pubmed-form');const query=document.querySelector<HTMLInputElement>('#pubmed-query');const status=document.querySelector<HTMLElement>('#pubmed-status');const results=document.querySelector<HTMLElement>('#pubmed-results');
form?.addEventListener('submit',async event=>{event.preventDefault();const q=query?.value.trim();if(!q||!status||!results)return;status.textContent='Searching the official NCBI PubMed service…';results.replaceChildren();try{const response=await fetch(`/api/pubmed-search?q=${encodeURIComponent(q)}&limit=10`,{headers:{Accept:'application/json'}});const data=await response.json();if(!response.ok)throw new Error(data.error||'Search failed');status.textContent=data.results.length?`Showing ${data.results.length} of ${Number(data.count).toLocaleString()} matching PubMed records.`:'No matching PubMed records were returned.';data.results.forEach((item:any)=>{const article=document.createElement('article');const meta=[item.authors.join(', '),item.journal,item.date,`PMID: ${item.pmid}`].filter(Boolean).join(' · ');article.innerHTML='<h2><a></a></h2><p class="result-meta"></p>';const a=article.querySelector('a');if(a){a.textContent=item.title;a.href=item.url;a.target='_blank';a.rel='noopener'}const p=article.querySelector('p');if(p)p.textContent=meta;if(item.doi){const doi=document.createElement('a');doi.className='doi-link';doi.href=`https://doi.org/${encodeURIComponent(item.doi)}`;doi.target='_blank';doi.rel='noopener';doi.textContent=`DOI ${item.doi}`;article.append(doi)}results.append(article)});}catch(error){status.textContent=error instanceof Error?error.message:'The search is temporarily unavailable.';const link=document.createElement('a');link.href=`https://pubmed.ncbi.nlm.nih.gov/?term=${encodeURIComponent(q)}`;link.target='_blank';link.rel='noopener';link.className='button button--outline';link.textContent='Continue on PubMed';results.append(link)}});
</script>
<style>.pubmed-layout{display:grid;grid-template-columns:minmax(0,1fr) minmax(17rem,.32fr);gap:3rem;align-items:start}.search-panel{padding:1.5rem;border:1px solid var(--line);background:var(--ivory);border-radius:var(--radius)}.search-panel label{font-weight:800}.search-panel>div{display:grid;grid-template-columns:1fr auto;gap:.6rem;margin-top:.5rem}.search-panel input{min-height:3.2rem;padding:.7rem .8rem;border:1px solid #aaa;border-radius:.25rem}.search-panel p,.pubmed-status{margin-top:.7rem;font-size:.78rem}.pubmed-results{display:grid;gap:1rem;margin-top:1.5rem}.pubmed-results article{padding:1.3rem;border:1px solid var(--line);border-radius:var(--radius);background:white}.pubmed-results h2{font-size:1.2rem}.pubmed-results h2 a{color:var(--plum-800)}.result-meta{margin-top:.55rem;font-size:.78rem}.doi-link{display:inline-block;margin-top:.6rem;font-size:.75rem;font-weight:750}@media(max-width:61.99rem){.pubmed-layout{grid-template-columns:1fr}}@media(max-width:40rem){.search-panel>div{grid-template-columns:1fr}}</style>
